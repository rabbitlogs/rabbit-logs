---
import BaseLayout from './BaseLayout.astro';
import AdSense from '../components/AdSense.astro';
import TableOfContents from '../components/TableOfContents.astro';

const { title, description, pubDate, category, lang = 'ko', headings = [] } = Astro.props;

const catName = {
  ko: { project: 'SAP 프로젝트', operations: 'SAP 실무운영', study: 'SAP 학습자료' },
  en: { project: 'SAP Projects', operations: 'SAP Operations', study: 'SAP Study Notes' },
};
const dateStr = new Date(pubDate).toLocaleDateString(lang === 'en' ? 'en-US' : 'ko-KR', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={description} lang={lang}>
  <article class="post">
    <div class="post-meta">
      <span class="cat">{catName[lang][category]}</span>
      <span class="date">{dateStr}</span>
    </div>
    <h1>{title}</h1>

    <!-- 목차: 도입부 앞, 3줄 요약 다음 자리 -->
    <TableOfContents headings={headings} lang={lang} />

    <div class="prose">
      <slot />
    </div>

    <!-- 본문 안 첫 소제목 뒤로 광고 1개를 자동 이동 -->
    <div id="incontent-ad" hidden><AdSense /></div>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const ad = document.getElementById('incontent-ad');
        const firstH2 = document.querySelector('.prose h2');
        if (ad && firstH2) {
          ad.hidden = false;
          firstH2.parentNode.insertBefore(ad, firstH2.nextSibling);
        }
      });
    </script>

    <!-- 광고: 마무리 뒤 (나가는 지점) -->
    <AdSense />
  </article>

  <style>
    .post { padding: 2.5rem 0; }
    .post-meta { display: flex; gap: 0.75rem; align-items: center; font-size: 0.85rem; margin-bottom: 1rem; }
    .cat { color: var(--accent); font-weight: 700; }
    .date { color: var(--muted); }
    .post h1 {
      font-family: var(--font-display);
      font-size: 2rem; line-height: 1.3; margin: 0 0 1.5rem;
      letter-spacing: -0.02em;
    }
  </style>
</BaseLayout>

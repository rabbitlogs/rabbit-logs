---
import BaseLayout from './BaseLayout.astro';
import AdSense from '../components/AdSense.astro';

const { title, description, pubDate, category, lang = 'ko' } = Astro.props;

const catName = {
  ko: { project: 'SAP 프로젝트', operations: 'SAP 실무운영', study: 'SAP 학습자료' },
  en: { project: 'SAP Projects', operations: 'SAP Operations', study: 'SAP Study Notes' },
};
const dateStr = new Date(pubDate).toLocaleDateString(lang === 'en' ? 'en-US' : 'ko-KR', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={description} lang={lang}>
  <article class="post">
    <div class="post-meta">
      <span class="cat">{catName[lang][category]}</span>
      <span class="date">{dateStr}</span>
    </div>
    <h1>{title}</h1>
    <p class="lede">{description}</p>

    <!-- ▼ 본문 시작 전 광고 자리 -->
    <AdSense />

    <div class="prose">
      <slot />
    </div>

    <!-- ▼ 본문 끝난 후 광고 자리 -->
    <AdSense />
  </article>

  <style>
    .post { padding: 2.5rem 0; }
    .post-meta { display: flex; gap: 0.75rem; align-items: center; font-size: 0.85rem; margin-bottom: 1rem; }
    .cat { color: var(--accent); font-weight: 600; }
    .date { color: var(--muted); }
    .post h1 { font-family: var(--font-display); font-size: 2.1rem; line-height: 1.25; margin: 0 0 0.75rem; letter-spacing: -0.02em; }
    .lede { font-size: 1.1rem; color: var(--muted); margin: 0 0 1rem; }
    .prose :global(h2) { font-family: var(--font-display); font-size: 1.5rem; margin-top: 2.5rem; }
    .prose :global(p) { margin: 1.1rem 0; }
  </style>
</BaseLayout>

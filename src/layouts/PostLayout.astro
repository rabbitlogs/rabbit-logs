---
import fs from 'node:fs';
import path from 'node:path';
import yaml from 'js-yaml';
import BaseLayout from './BaseLayout.astro';
import AdSense from '../components/AdSense.astro';

const { title, description, pubDate, category, lang = 'ko', tags = [], slug, thumbnail } = Astro.props;

const catName = {
  ko: { project: 'SAP 프로젝트', operations: 'SAP 실무운영', study: 'SAP 학습자료' },
  en: { project: 'SAP Projects', operations: 'SAP Operations', study: 'SAP Study Notes' },
};
const dateStr = new Date(pubDate).toLocaleDateString(lang === 'en' ? 'en-US' : 'ko-KR', {
  year: 'numeric', month: 'long', day: 'numeric',
});

// JSON-LD (Article 구조화 데이터)
// 검색엔진이 이 글의 제목, 저자, 작성일, 이미지를 명확히 인식하도록 돕는 메타데이터.
// 화면에는 아무 것도 렌더링되지 않고, head에 application/ld+json 스크립트로만 삽입된다.
const siteUrl = 'https://rabbitlogs.com';
const pageUrl = lang === 'en' ? siteUrl + '/en/blog/' + slug : siteUrl + '/blog/' + slug;
const ogImage = thumbnail ? siteUrl + thumbnail : siteUrl + '/og-thumbnail.jpg';
const isoDate = new Date(pubDate).toISOString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: ogImage,
  datePublished: isoDate,
  dateModified: isoDate,
  author: {
    '@type': 'Person',
    name: 'Rabbit',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Rabbit Logs',
    logo: {
      '@type': 'ImageObject',
      url: siteUrl + '/rabbit-logo.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageUrl,
  },
};

// ── 1-hop 미니맵: book-index.yaml에서 이 글과 직접 연결된 글만 모은다 (ko 전용) ──
const catColor = { project: '#2c5f57', operations: '#3b6ea5', study: '#d99441', stats: '#a8516e' };
let miniMap = null;
if (lang === 'ko' && slug) {
  try {
    const yamlPath = path.resolve('./src/data/book-index.yaml');
    const entries = yaml.load(fs.readFileSync(yamlPath, 'utf-8'));
    const bySlug = {};
    entries.forEach((e) => (bySlug[e.slug] = e));
    const me = bySlug[slug];
    if (me && me.status === 'rebuilt') {
      // 이 글이 직접 가리키는 관계(나가는 edge) + 다른 글이 이 글을 가리키는 관계(들어오는 edge)
      // 들어오는 쪽은 방향을 뒤집어 같은 타입으로 표시한다
      //   (A가 B의 prerequisite ⇒ B 입장에선 A가 "먼저 읽으면 좋은 글"이므로 동일하게 prerequisite로 취급)
      const neighborType = {};
      const rel = me.relations || {};
      (rel.prerequisite || []).forEach((id) => (neighborType[id] = 'prerequisite'));
      (rel.related || []).forEach((id) => (neighborType[id] = neighborType[id] || 'related'));
      (rel.deepens || []).forEach((id) => (neighborType[id] = 'deepens'));

      entries.forEach((e) => {
        if (e.slug === slug || !e.relations) return;
        if ((e.relations.prerequisite || []).includes(slug)) neighborType[e.slug] = neighborType[e.slug] || 'prerequisite';
        if ((e.relations.related || []).includes(slug)) neighborType[e.slug] = neighborType[e.slug] || 'related';
        if ((e.relations.deepens || []).includes(slug)) neighborType[e.slug] = 'deepens';
      });

      const neighborIds = Object.keys(neighborType).filter((id) => bySlug[id] && bySlug[id].status === 'rebuilt');

      if (neighborIds.length > 0) {
        const cx = 150, cy = 110, R = 72;
        const N = neighborIds.length;
        const neighbors = neighborIds.map((id, i) => {
          const angle = -Math.PI / 2 + (i * 2 * Math.PI) / N;
          return {
            slug: id,
            title: bySlug[id].mapTitle || bySlug[id].title,
            category: bySlug[id].category,
            type: neighborType[id],
            x: Math.round(cx + R * Math.cos(angle)),
            y: Math.round(cy + R * Math.sin(angle)),
          };
        });

        miniMap = {
          center: { title: me.mapTitle || me.title, category: me.category, x: cx, y: cy },
          neighbors,
        };
      }
    }
  } catch (e) {
    miniMap = null; // book-index.yaml이 없거나 파싱 실패해도 글 자체는 정상 출력
  }
}
---

<BaseLayout title={title} description={description} lang={lang} showAds={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="post">
    <div class="post-meta">
      <span class="cat">{catName[lang][category]}</span>
      <span class="date">{dateStr}</span>
    </div>
    <h1>{title}</h1>
    <p class="subtitle">{description}</p>

    <div class="prose">
      <slot />
    </div>

    {miniMap && (
      <div class="mini-map">
        <div class="mini-map-head">
          <span class="mini-map-label">🗺️ 이 글과 연결된 글</span>
          <a href="/map" class="mini-map-all">전체 지도 보기 →</a>
        </div>
        <svg viewBox="0 0 300 220" class="mini-map-svg" role="img" aria-label="관련 글 관계도">
          {miniMap.neighbors.map((n) => (
            <line
              x1={miniMap.center.x} y1={miniMap.center.y}
              x2={n.x} y2={n.y}
              stroke={n.type === 'deepens' ? '#d99441' : '#a8a194'}
              stroke-width={n.type === 'deepens' ? 1.8 : 1}
              stroke-dasharray={n.type === 'related' ? '3,3' : 'none'}
            />
          ))}
          <circle cx={miniMap.center.x} cy={miniMap.center.y} r="9" fill={catColor[miniMap.center.category]} stroke="#fff" stroke-width="1.5" />
          <text x={miniMap.center.x} y={miniMap.center.y + 22} text-anchor="middle" class="mm-center-label">{miniMap.center.title}</text>
          {miniMap.neighbors.map((n) => (
            <a href={`/blog/${n.slug}`}>
              <circle cx={n.x} cy={n.y} r="6" fill={catColor[n.category]} stroke="#fff" stroke-width="1.2" />
              <text x={n.x} y={n.y + (n.y > miniMap.center.y ? 16 : -10)} text-anchor="middle" class="mm-label">{n.title}</text>
            </a>
          ))}
        </svg>
        <div class="mini-map-legend">
          <span><i class="mm-line solid"></i> 선행</span>
          <span><i class="mm-line dashed"></i> 관련</span>
          <span><i class="mm-line thick"></i> 심화</span>
        </div>
      </div>
    )}

    {tags && tags.length > 0 && (
      <div class="post-tags">
        {tags.map((tag) => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    )}

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        // 본문(.prose) 안의 "내부 링크"를 새 탭으로 열리게 한다.
        // 외부 링크는 이미 astro.config의 rehype-external-links가 처리하므로 대상 아님.
        // 제외 대상: ① 목차(#섹션) 같은 같은 페이지 점프 링크
        //           ② "더 읽어보기 / Read more" 관련글 목록(같은 탭 유지)
        const prose = document.querySelector('.prose');
        if (!prose) return;

        // "더 읽어보기"/"Read more" 단락을 찾아, 그 이후(관련글 목록 등)는 전부 제외 구간으로 본다.
        const markers = Array.from(prose.querySelectorAll('strong')).filter(
          (el) => el.textContent.trim() === '더 읽어보기' || el.textContent.trim() === 'Read more'
        );
        let excludeFrom = null;
        if (markers.length) {
          // 보통 <p><strong>더 읽어보기</strong></p> 형태이므로 그 상위 요소부터 제외 시작.
          excludeFrom = markers[0].closest('p') || markers[0];
        }

        const isExcluded = (a) => {
          if (!excludeFrom) return false;
          // DOM 순서상 excludeFrom과 같거나 그 뒤에 있는 요소인지 확인.
          const pos = excludeFrom.compareDocumentPosition(a);
          return !!(pos & Node.DOCUMENT_POSITION_FOLLOWING) || excludeFrom.contains(a);
        };

        prose.querySelectorAll('a[href]').forEach((a) => {
          const href = a.getAttribute('href') || '';
          if (href.startsWith('#')) return;              // 같은 페이지 점프 링크
          if (a.target === '_blank') return;              // 이미 새탭 처리된 외부 링크
          if (isExcluded(a)) return;                       // 더 읽어보기 구간
          a.setAttribute('target', '_blank');
          a.setAttribute('rel', 'noopener noreferrer');
        });
      });
    </script>

    <!--
      광고 원본 1칸(숨김). JS가 본문 글자수를 재서 2~3개로 복제·배치한다.
        0~3,500자 : 2개 (첫 소제목 뒤 + 태그 뒤)
        3,500자+  : 3개 (도입 뒤 + 중간 소제목 뒤 + 태그 뒤)
      ※ 마지막 광고는 본문(.prose)이 아니라 태그(.post-tags) 다음, article 끝에 둔다.
      ※ 광고가 채워진 뒤 iframe 실제 높이를 읽어 ins 높이를 맞춘다(모바일 빈 공간 제거).
    -->
    <template id="ad-template"><AdSense /></template>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const article = document.querySelector('.post');
        const prose = document.querySelector('.prose');
        const tags = document.querySelector('.post-tags'); // 없을 수도 있음
        const tpl = document.getElementById('ad-template');
        if (!article || !prose || !tpl) return;

        // 1) 본문 글자수로 광고 개수 결정 (1개짜리 없음)
        const len = (prose.textContent || '').replace(/\s/g, '').length;
        const count = len >= 3500 ? 3 : 2;

        const makeAd = () => tpl.content.firstElementChild.cloneNode(true);
        const placed = [];

        const insertBeforeInProse = (node) => {
          const ad = makeAd();
          node.parentNode.insertBefore(ad, node);
          placed.push(ad);
        };
        const appendAfterTags = () => {
          const ad = makeAd();
          ad.classList.add('ad-last'); // 글 끝(푸터 직전) 광고 → 아래 여백 줄임
          if (tags) tags.insertAdjacentElement('afterend', ad);
          else article.appendChild(ad);
          placed.push(ad);
        };

        const h2s = prose.querySelectorAll('h2');

        // 첫 광고 위치: 두 번째 소제목 앞으로 한 칸 미룸(체감 광고 밀도를 낮추기 위함).
        // 소제목이 1개뿐인 짧은 글은 h2s[1]이 없으므로 h2s[0]으로 폴백한다.
        const firstAdAnchor = h2s[1] || h2s[0];

        if (count === 2) {
          if (firstAdAnchor) insertBeforeInProse(firstAdAnchor);
          appendAfterTags();
        } else {
          if (firstAdAnchor) insertBeforeInProse(firstAdAnchor);
          if (h2s.length >= 3) {
            insertBeforeInProse(h2s[Math.floor(h2s.length / 2)]);
          } else if (h2s[1] && h2s[1] !== firstAdAnchor) {
            insertBeforeInProse(h2s[1]);
          }
          appendAfterTags();
        }

        // 2) 애드센스 렌더 요청
        placed.forEach(() => {
          try { (window.adsbygoogle = window.adsbygoogle || []).push({}); } catch (e) {}
        });

        // 3) fluid(인아티클) 광고는 스스로 콘텐츠 높이만큼만 차지하므로
        //    높이를 강제하지 않는다(강제하면 오히려 잘리거나 빈칸이 생김).
        //    대신 일정 시간 안에 광고가 안 채워지면(미충전 또는 광고차단 프로그램)
        //    빈 박스가 남지 않도록 박스를 통째로 제거한다.
        placed.forEach((slot) => {
          const ins = slot.querySelector('ins.adsbygoogle');
          if (!ins) return;

          let tries = 0;
          const checker = setInterval(() => {
            tries++;
            const status = ins.getAttribute('data-ad-status');
            const iframe = ins.querySelector('iframe');

            if (status === 'unfilled') {
              slot.remove();              // 미충전 → 박스 제거
              clearInterval(checker);
            } else if (iframe && iframe.offsetHeight > 0) {
              clearInterval(checker);     // 광고 정상 표시 → 그대로 둠
            } else if (tries >= 12) {
              // 약 3초(250ms*12) 지나도 광고(iframe)가 안 생기면
              // 광고차단 프로그램 등으로 못 뜬 것 → 빈 박스 제거
              slot.remove();
              clearInterval(checker);
            }
          }, 250);
        });
      });
    </script>

    <!--
      라이트박스: 본문(.prose) 안의 이미지를 클릭하면 확대 팝업으로 보여준다.
      ※ 본문에 광고가 삽입된 뒤(위 스크립트) 동작해야 새로 추가될 이미지가 없으므로 순서 그대로 둔다.
      ※ alt 텍스트를 캡션으로 사용(없으면 캡션 영역 숨김).
    -->
    <div id="lightbox" class="lightbox" hidden>
      <button type="button" class="lightbox-close" aria-label="닫기">✕</button>
      <img class="lightbox-img" src="" alt="" />
      <p class="lightbox-caption"></p>
    </div>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const prose = document.querySelector('.prose');
        const lightbox = document.getElementById('lightbox');
        if (!prose || !lightbox) return;

        const lbImg = lightbox.querySelector('.lightbox-img');
        const lbCaption = lightbox.querySelector('.lightbox-caption');
        const lbClose = lightbox.querySelector('.lightbox-close');
        let lastFocused = null;

        const openLightbox = (img) => {
          lastFocused = document.activeElement;
          lbImg.src = img.currentSrc || img.src;
          lbImg.alt = img.alt || '';
          if (img.alt) {
            lbCaption.textContent = img.alt;
            lbCaption.hidden = false;
          } else {
            lbCaption.textContent = '';
            lbCaption.hidden = true;
          }
          lightbox.hidden = false;
          document.body.style.overflow = 'hidden';
          lbClose.focus();
        };

        const closeLightbox = () => {
          lightbox.hidden = true;
          lbImg.src = '';
          document.body.style.overflow = '';
          if (lastFocused) lastFocused.focus();
        };

        // 본문 안의 이미지를 wrapper로 감싸 클릭 영역을 잡는다.
        // (호버 시 이미지가 살짝 어두워지는 것만으로 클릭 가능함을 알린다 — 별도 아이콘 없음)
        prose.querySelectorAll('img').forEach((img) => {
          img.classList.add('lightbox-trigger');

          const wrap = document.createElement('span');
          wrap.className = 'lightbox-zoom-wrap';
          wrap.tabIndex = 0;
          wrap.setAttribute('role', 'button');
          wrap.setAttribute('aria-label', '이미지 확대');
          img.parentNode.insertBefore(wrap, img);
          wrap.appendChild(img);

          wrap.addEventListener('click', () => openLightbox(img));
          wrap.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              openLightbox(img);
            }
          });
        });

        lbClose.addEventListener('click', closeLightbox);
        lightbox.addEventListener('click', (e) => {
          if (e.target === lightbox) closeLightbox();
        });
        document.addEventListener('keydown', (e) => {
          if (!lightbox.hidden && e.key === 'Escape') closeLightbox();
        });
      });
    </script>
  </article>

  <style>
    .post { padding: 2.5rem 0; }
    .post-meta { display: flex; gap: 0.75rem; align-items: center; font-size: 0.85rem; margin-bottom: 1rem; }
    .cat { color: var(--accent); font-weight: 700; }
    .date { color: var(--muted); }
    .post h1 {
      font-size: 2rem; font-weight: 800; line-height: 1.3; margin: 0 0 0.6rem;
      letter-spacing: -0.03em;
    }
    .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 2rem 0 0.5rem; }
    .mini-map {
      margin: 2rem 0 0;
      padding: 1rem 1.1rem 0.6rem;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #faf8f3;
    }
    .mini-map-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.3rem; }
    .mini-map-label { font-size: 0.85rem; font-weight: 700; color: var(--ink, #2a2a26); }
    .mini-map-all { font-size: 0.8rem; color: var(--primary); text-decoration: none; font-weight: 600; white-space: nowrap; }
    .mini-map-all:hover { text-decoration: underline; }
    .mini-map-svg { width: 100%; max-width: 420px; height: auto; display: block; margin: 0 auto; }
    .mini-map-svg a { cursor: pointer; }
    .mm-label { font-size: 8.5px; fill: #6b6555; }
    .mini-map-svg a:hover .mm-label { fill: var(--primary); font-weight: 700; }
    .mini-map-svg a:hover circle { stroke: var(--primary); }
    .mm-center-label { font-size: 9px; font-weight: 700; fill: var(--ink, #2a2a26); }
    .mini-map-legend {
      display: flex; gap: 14px; flex-wrap: wrap; justify-content: center;
      margin-top: 0.3rem; padding-bottom: 0.6rem;
      font-size: 10.5px; color: #6b6555;
    }
    .mini-map-legend .mm-line { display: inline-block; width: 16px; height: 0; vertical-align: middle; margin-right: 4px; border-top: 1.4px solid #a8a194; }
    .mini-map-legend .mm-line.dashed { border-top-style: dashed; }
    .mini-map-legend .mm-line.thick { border-top-width: 2.2px; border-top-color: #d99441; }
    .post-tags .tag {
      font-size: 0.85rem; color: var(--primary); background: rgba(44,95,87,0.07);
      border: 1px solid rgba(44,95,87,0.15); border-radius: 999px; padding: 0.25rem 0.75rem;
    }
    .subtitle {
      font-size: 1.05rem; color: var(--muted); line-height: 1.6;
      margin: 0 0 1.8rem; font-weight: 400;
    }
    /* 글 끝(푸터 직전) 광고는 아래 여백을 줄여 푸터와 간격을 좁힌다.
       (광고 박스 기본 margin 2.5rem + 푸터 margin-top 4rem이 겹쳐 벌어지는 것 보정) */
    .post :global(.ad-slot.ad-last) { margin-bottom: 0; }

    /* 본문 이미지 확대 아이콘 오버레이 (브라우저 기본 zoom 커서는 쓰지 않음 — 아이콘 하나만 보이게 pointer 사용) */
    .post :global(.prose .lightbox-zoom-wrap) {
      position: relative;
      display: block;
      cursor: pointer;
      border-radius: 8px;
      margin: 1.5rem auto 0.1rem;
      max-width: 100%;
    }
    .post :global(.prose .lightbox-zoom-wrap img) {
      transition: filter 0.15s;
      margin: 0;
      display: block;
    }
    .post :global(.prose .lightbox-zoom-wrap:hover img),
    .post :global(.prose .lightbox-zoom-wrap:focus-visible img) {
      filter: brightness(0.93);
    }
    .post :global(.prose .lightbox-zoom-wrap:focus-visible) {
      outline: 2px solid var(--primary);
      outline-offset: 2px;
    }
  </style>

  <style is:global>
    /* 라이트박스(이미지 확대 팝업) */
    .lightbox {
      position: fixed; inset: 0; z-index: 999;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 0.9rem; padding: 2.5rem 1.25rem;
      background: rgba(32, 37, 31, 0.92);
      cursor: zoom-out;
    }
    .lightbox[hidden] { display: none; }
    .lightbox-img {
      max-width: 100%; max-height: 80vh;
      border-radius: 8px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.4);
      cursor: default;
    }
    .lightbox-caption {
      margin: 0; max-width: 640px;
      color: #f3f0e8; font-size: 0.92rem; line-height: 1.6;
      text-align: center; cursor: default;
    }
    .lightbox-caption[hidden] { display: none; }
    .lightbox-close {
      position: absolute; top: 1.1rem; right: 1.25rem;
      width: 40px; height: 40px;
      display: inline-flex; align-items: center; justify-content: center;
      background: rgba(255,255,255,0.1); border: none; border-radius: 999px;
      color: #fff; font-size: 1.1rem; line-height: 1; cursor: pointer;
      transition: background 0.15s;
    }
    .lightbox-close:hover { background: rgba(255,255,255,0.22); }
    .lightbox-close:focus-visible { outline: 2px solid #fff; outline-offset: 2px; }

    @media (max-width: 640px) {
      .lightbox { padding: 1.5rem 1rem; }
      .lightbox-img { max-height: 72vh; }
      .lightbox-close { top: 0.7rem; right: 0.8rem; width: 36px; height: 36px; }
    }

---
import BaseLayout from './BaseLayout.astro';
import AdSense from '../components/AdSense.astro';

const { title, description, pubDate, category, lang = 'ko', tags = [] } = Astro.props;

const catName = {
  ko: { project: 'SAP 프로젝트', operations: 'SAP 실무운영', study: 'SAP 학습자료' },
  en: { project: 'SAP Projects', operations: 'SAP Operations', study: 'SAP Study Notes' },
};
const dateStr = new Date(pubDate).toLocaleDateString(lang === 'en' ? 'en-US' : 'ko-KR', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={description} lang={lang}>
  <article class="post">
    <div class="post-meta">
      <span class="cat">{catName[lang][category]}</span>
      <span class="date">{dateStr}</span>
    </div>
    <h1>{title}</h1>
    <p class="subtitle">{description}</p>

    <div class="prose">
      <slot />
    </div>

    {tags && tags.length > 0 && (
      <div class="post-tags">
        {tags.map((tag) => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    )}

    <!--
      광고 원본 1칸(숨김). JS가 본문 글자수를 재서 1~3개로 복제·배치한다.
        ~2,000자  : 1개 (첫 h2 앞)
        2,000~3,500자: 2개 (첫 h2 앞 + 글 끝)
        3,500자+  : 3개 (첫 h2 앞 + 중간 h2 앞 + 글 끝)
    -->
    <template id="ad-template"><AdSense /></template>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const prose = document.querySelector('.prose');
        const tpl = document.getElementById('ad-template');
        if (!prose || !tpl) return;

        // 1) 본문 글자수로 광고 개수 결정
        const len = (prose.textContent || '').replace(/\s/g, '').length;
        let count = 1;
        if (len >= 3500) count = 3;
        else if (len >= 2000) count = 2;

        // 2) 본문 안 h2 목록
        const h2s = prose.querySelectorAll('h2');

        // 광고 칸 하나를 복제해 특정 노드 '앞'에 삽입
        const insertBefore = (node) => {
          const ad = tpl.content.firstElementChild.cloneNode(true);
          node.parentNode.insertBefore(ad, node);
          return ad;
        };
        // 본문 맨 끝에 삽입
        const appendEnd = () => {
          const ad = tpl.content.firstElementChild.cloneNode(true);
          prose.appendChild(ad);
          return ad;
        };

        const placed = [];

        if (count === 1) {
          if (h2s[0]) placed.push(insertBefore(h2s[0]));
          else placed.push(appendEnd());
        } else if (count === 2) {
          if (h2s[0]) placed.push(insertBefore(h2s[0]));
          placed.push(appendEnd());
        } else {
          // 3개: 첫 h2 앞 + 중간 h2 앞 + 글 끝
          if (h2s[0]) placed.push(insertBefore(h2s[0]));
          if (h2s.length >= 3) {
            const mid = h2s[Math.floor(h2s.length / 2)];
            placed.push(insertBefore(mid));
          }
          placed.push(appendEnd());
        }

        // 3) 삽입된 광고들에 대해 애드센스 렌더 요청
        placed.forEach(() => {
          try { (window.adsbygoogle = window.adsbygoogle || []).push({}); } catch (e) {}
        });
      });
    </script>
  </article>

  <style>
    .post { padding: 2.5rem 0; }
    .post-meta { display: flex; gap: 0.75rem; align-items: center; font-size: 0.85rem; margin-bottom: 1rem; }
    .cat { color: var(--accent); font-weight: 700; }
    .date { color: var(--muted); }
    .post h1 {
      font-size: 2rem; font-weight: 800; line-height: 1.3; margin: 0 0 0.6rem;
      letter-spacing: -0.03em;
    }
    .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 2rem 0 0.5rem; }
    .post-tags .tag {
      font-size: 0.85rem; color: var(--primary); background: rgba(44,95,87,0.07);
      border: 1px solid rgba(44,95,87,0.15); border-radius: 999px; padding: 0.25rem 0.75rem;
    }
    .subtitle {
      font-size: 1.05rem; color: var(--muted); line-height: 1.6;
      margin: 0 0 1.8rem; font-weight: 400;
    }
  </style>
</BaseLayout>

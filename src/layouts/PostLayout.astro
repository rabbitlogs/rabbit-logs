---
import fs from 'node:fs';
import path from 'node:path';
import yaml from 'js-yaml';
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import AdSense from '../components/AdSense.astro';

const { title, description, pubDate, category, lang = 'ko', tags = [], slug, thumbnail, essay = false } = Astro.props;

const catName = {
  ko: { project: 'SAP 프로젝트', operations: 'SAP 실무운영', study: 'SAP 학습자료', stats: '통계·데이터' },
  en: { project: 'SAP Projects', operations: 'SAP Operations', study: 'SAP Study Notes', stats: 'Stats & Data' },
};
const miniMapText = {
  ko: { label: '🗺️ 이 글과 연결된 글', allLink: '전체 지도 보기 →', mapHref: '/map', prerequisite: '선행', related: '관련', deepens: '심화' },
  en: { label: '🗺️ Related articles', allLink: 'View full map →', mapHref: '/en/map', prerequisite: 'Prerequisite', related: 'Related', deepens: 'Deep dive' },
};
const mmt = miniMapText[lang] || miniMapText.ko;
const dateStr = new Date(pubDate).toLocaleDateString(lang === 'en' ? 'en-US' : 'ko-KR', {
  year: 'numeric', month: 'long', day: 'numeric',
});

// JSON-LD (Article 구조화 데이터)
// 검색엔진이 이 글의 제목, 저자, 작성일, 이미지를 명확히 인식하도록 돕는 메타데이터.
// 화면에는 아무 것도 렌더링되지 않고, head에 application/ld+json 스크립트로만 삽입된다.
const siteUrl = 'https://rabbitlogs.com';
const pageUrl = lang === 'en' ? siteUrl + '/en/blog/' + slug : siteUrl + '/blog/' + slug;
const ogImage = thumbnail ? siteUrl + thumbnail : siteUrl + '/og-thumbnail.jpg';
const isoDate = new Date(pubDate).toISOString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: ogImage,
  datePublished: isoDate,
  dateModified: isoDate,
  author: {
    '@type': 'Person',
    name: 'Rabbit',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Rabbit Logs',
    logo: {
      '@type': 'ImageObject',
      url: siteUrl + '/rabbit-logo.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageUrl,
  },
};

// ── 1-hop 미니맵: book-index.yaml(ko 슬러그 기준 관계)에서 이 글과 직접 연결된 글만 모은다 ──
// en 글은 슬러그를 ko와 동일하게 쓰므로 관계 그래프는 그대로 재사용하고,
// "실제로 그 언어의 번역이 존재하는 슬러그"만 이웃으로 남긴다.
const catColor = { project: '#2c5f57', operations: '#3b6ea5', study: '#d99441', stats: '#a8516e' };
let miniMap = null;
if (slug) {
  try {
    const yamlPath = path.resolve('./src/data/book-index.yaml');
    const entries = yaml.load(fs.readFileSync(yamlPath, 'utf-8'));
    const bySlug = {};
    entries.forEach((e) => (bySlug[e.slug] = e));
    const me = bySlug[slug];

    // 이 글의 언어에 실제로 존재하는 슬러그 집합 (en이면 en 콘텐츠만, ko면 ko 콘텐츠만)
    const existingSlugs = new Set(
      (await getCollection('blog'))
        .filter((p) => p.id.startsWith(lang + '/'))
        .map((p) => p.id.replace(lang + '/', '').replace('.md', ''))
    );

    // 언어별 제목/mapTitle 오버라이드 (book-index.yaml은 ko 제목만 가지므로 en일 땐 실제 en 콘텐츠에서 가져온다)
    const titleOverride = {};
    if (lang === 'en') {
      (await getCollection('blog'))
        .filter((p) => p.id.startsWith('en/'))
        .forEach((p) => {
          const s = p.id.replace('en/', '').replace('.md', '');
          titleOverride[s] = { title: p.data.title, mapTitle: p.data.mapTitle };
        });
    }

    if (me && me.status === 'rebuilt' && existingSlugs.has(slug)) {
      // 이 글이 직접 가리키는 관계(나가는 edge) + 다른 글이 이 글을 가리키는 관계(들어오는 edge)
      // 들어오는 쪽은 방향을 뒤집어 같은 타입으로 표시한다
      //   (A가 B의 prerequisite ⇒ B 입장에선 A가 "먼저 읽으면 좋은 글"이므로 동일하게 prerequisite로 취급)
      const neighborType = {};
      const rel = me.relations || {};
      (rel.prerequisite || []).forEach((id) => (neighborType[id] = 'prerequisite'));
      (rel.related || []).forEach((id) => (neighborType[id] = neighborType[id] || 'related'));
      (rel.deepens || []).forEach((id) => (neighborType[id] = 'deepens'));

      entries.forEach((e) => {
        if (e.slug === slug || !e.relations) return;
        if ((e.relations.prerequisite || []).includes(slug)) neighborType[e.slug] = neighborType[e.slug] || 'prerequisite';
        if ((e.relations.related || []).includes(slug)) neighborType[e.slug] = neighborType[e.slug] || 'related';
        if ((e.relations.deepens || []).includes(slug)) neighborType[e.slug] = 'deepens';
      });

      // rebuilt 상태 + 실제로 이 언어의 번역이 존재하는 슬러그만 이웃으로 남긴다
      const neighborIds = Object.keys(neighborType).filter(
        (id) => bySlug[id] && bySlug[id].status === 'rebuilt' && existingSlugs.has(id)
      );

      if (neighborIds.length > 0) {
        const cx = 150, cy = 110, R = 72;
        const N = neighborIds.length;
        const neighbors = neighborIds.map((id, i) => {
          const angle = -Math.PI / 2 + (i * 2 * Math.PI) / N;
          const ov = titleOverride[id];
          return {
            slug: id,
            title: (ov && (ov.mapTitle || ov.title)) || bySlug[id].mapTitle || bySlug[id].title,
            category: bySlug[id].category,
            type: neighborType[id],
            x: Math.round(cx + R * Math.cos(angle)),
            y: Math.round(cy + R * Math.sin(angle)),
          };
        });

        const meOv = titleOverride[slug];
        miniMap = {
          center: {
            title: (meOv && (meOv.mapTitle || meOv.title)) || me.mapTitle || me.title,
            category: me.category,
            x: cx,
            y: cy,
          },
          neighbors,
        };
      }
    }
  } catch (e) {
    miniMap = null; // book-index.yaml이 없거나 파싱 실패해도 글 자체는 정상 출력
  }
}
---

<BaseLayout title={title} description={description} lang={lang} showAds={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- 읽기 진행바: 화면 최상단 고정, 본문(article) 기준 스크롤 진행률 표시 -->
  <div id="reading-progress" class="reading-progress" aria-hidden="true">
    <div class="reading-progress-bar"></div>
  </div>

  <div class="post-grid">
  <article class="post">
    <div class="post-meta">
      <span class="cat">{catName[lang][category]}</span>
      <span class="date">{dateStr}</span>
    </div>
    <h1>{title}</h1>
    <p class="subtitle">{description}</p>

    <div class={`prose prose-${category}${essay ? ' prose-essay' : ''}`}>
      <slot />
    </div>

    {miniMap && (
      <div class="mini-map">
        <div class="mini-map-head">
          <span class="mini-map-label">{mmt.label}</span>
          <a href={mmt.mapHref} class="mini-map-all">{mmt.allLink}</a>
        </div>
        <svg viewBox="0 0 300 220" class="mini-map-svg" role="img" aria-label={lang === 'en' ? 'Related articles diagram' : '관련 글 관계도'}>
          {miniMap.neighbors.map((n) => (
            <line
              x1={miniMap.center.x} y1={miniMap.center.y}
              x2={n.x} y2={n.y}
              stroke={n.type === 'deepens' ? '#d99441' : '#a8a194'}
              stroke-width={n.type === 'deepens' ? 1.8 : 1}
              stroke-dasharray={n.type === 'related' ? '3,3' : 'none'}
            />
          ))}
          <circle cx={miniMap.center.x} cy={miniMap.center.y} r="9" fill={catColor[miniMap.center.category]} stroke="#fff" stroke-width="1.5" />
          <text x={miniMap.center.x} y={miniMap.center.y + 22} text-anchor="middle" class="mm-center-label">{miniMap.center.title}</text>
          {miniMap.neighbors.map((n) => (
            <a href={`${lang === 'en' ? '/en' : ''}/blog/${n.slug}`}>
              <circle cx={n.x} cy={n.y} r="6" fill={catColor[n.category]} stroke="#fff" stroke-width="1.2" />
              <text x={n.x} y={n.y + (n.y > miniMap.center.y ? 16 : -10)} text-anchor="middle" class="mm-label">{n.title}</text>
            </a>
          ))}
        </svg>
        <div class="mini-map-legend">
          <span><i class="mm-line solid"></i> {mmt.prerequisite}</span>
          <span><i class="mm-line dashed"></i> {mmt.related}</span>
          <span><i class="mm-line thick"></i> {mmt.deepens}</span>
        </div>
      </div>
    )}

    {tags && tags.length > 0 && (
      <div class="post-tags">
        {tags.map((tag) => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    )}

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        // 본문(.prose) 안의 "내부 링크"를 새 탭으로 열리게 한다.
        // 외부 링크는 이미 astro.config의 rehype-external-links가 처리하므로 대상 아님.
        // 제외 대상: ① 목차(#섹션) 같은 같은 페이지 점프 링크
        //           ② "더 읽어보기 / Read more" 관련글 목록(같은 탭 유지)
        const prose = document.querySelector('.prose');
        if (!prose) return;

        // "더 읽어보기"/"Read more" 단락을 찾아, 그 이후(관련글 목록 등)는 전부 제외 구간으로 본다.
        const markers = Array.from(prose.querySelectorAll('strong')).filter(
          (el) => el.textContent.trim() === '더 읽어보기' || el.textContent.trim() === 'Read more'
        );
        let excludeFrom = null;
        if (markers.length) {
          // 보통 <p><strong>더 읽어보기</strong></p> 형태이므로 그 상위 요소부터 제외 시작.
          excludeFrom = markers[0].closest('p') || markers[0];
        }

        const isExcluded = (a) => {
          if (!excludeFrom) return false;
          // DOM 순서상 excludeFrom과 같거나 그 뒤에 있는 요소인지 확인.
          const pos = excludeFrom.compareDocumentPosition(a);
          return !!(pos & Node.DOCUMENT_POSITION_FOLLOWING) || excludeFrom.contains(a);
        };

        prose.querySelectorAll('a[href]').forEach((a) => {
          const href = a.getAttribute('href') || '';
          if (href.startsWith('#')) return;              // 같은 페이지 점프 링크
          if (a.target === '_blank') return;              // 이미 새탭 처리된 외부 링크
          if (isExcluded(a)) return;                       // 더 읽어보기 구간
          a.setAttribute('target', '_blank');
          a.setAttribute('rel', 'noopener noreferrer');
        });
      });
    </script>

    <!--
      광고 원본 1칸(숨김). JS가 본문 글자수를 재서 2~3개로 복제·배치한다.
        0~3,500자 : 2개 (첫 소제목 뒤 + 태그 뒤)
        3,500자+  : 3개 (도입 뒤 + 중간 소제목 뒤 + 태그 뒤)
      ※ 마지막 광고는 본문(.prose)이 아니라 태그(.post-tags) 다음, article 끝에 둔다.
      ※ 광고가 채워진 뒤 iframe 실제 높이를 읽어 ins 높이를 맞춘다(모바일 빈 공간 제거).
    -->
    <template id="ad-template"><AdSense /></template>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const article = document.querySelector('.post');
        const prose = document.querySelector('.prose');
        const tags = document.querySelector('.post-tags'); // 없을 수도 있음
        const tpl = document.getElementById('ad-template');
        if (!article || !prose || !tpl) return;

        // 1) 본문 글자수로 광고 개수 결정 (1개짜리 없음)
        const len = (prose.textContent || '').replace(/\s/g, '').length;
        const count = len >= 3500 ? 3 : 2;

        const makeAd = () => tpl.content.firstElementChild.cloneNode(true);
        const placed = [];

        const insertBeforeInProse = (node) => {
          const ad = makeAd();
          node.parentNode.insertBefore(ad, node);
          placed.push(ad);
        };
        const appendAfterTags = () => {
          const ad = makeAd();
          ad.classList.add('ad-last'); // 글 끝(푸터 직전) 광고 → 아래 여백 줄임
          if (tags) tags.insertAdjacentElement('afterend', ad);
          else article.appendChild(ad);
          placed.push(ad);
        };

        const h2s = prose.querySelectorAll('h2');

        // 첫 광고 위치: 두 번째 소제목 앞으로 한 칸 미룸(체감 광고 밀도를 낮추기 위함).
        // 소제목이 1개뿐인 짧은 글은 h2s[1]이 없으므로 h2s[0]으로 폴백한다.
        const firstAdAnchor = h2s[1] || h2s[0];

        if (count === 2) {
          if (firstAdAnchor) insertBeforeInProse(firstAdAnchor);
          appendAfterTags();
        } else {
          if (firstAdAnchor) insertBeforeInProse(firstAdAnchor);
          if (h2s.length >= 3) {
            insertBeforeInProse(h2s[Math.floor(h2s.length / 2)]);
          } else if (h2s[1] && h2s[1] !== firstAdAnchor) {
            insertBeforeInProse(h2s[1]);
          }
          appendAfterTags();
        }

        // 2) 애드센스 렌더 요청
        placed.forEach(() => {
          try { (window.adsbygoogle = window.adsbygoogle || []).push({}); } catch (e) {}
        });

        // 3) fluid(인아티클) 광고는 스스로 콘텐츠 높이만큼만 차지하므로
        //    높이를 강제하지 않는다(강제하면 오히려 잘리거나 빈칸이 생김).
        //    대신 일정 시간 안에 광고가 안 채워지면(미충전 또는 광고차단 프로그램)
        //    빈 박스가 남지 않도록 박스를 통째로 제거한다.
        placed.forEach((slot) => {
          const ins = slot.querySelector('ins.adsbygoogle');
          if (!ins) return;

          let tries = 0;
          const checker = setInterval(() => {
            tries++;
            const status = ins.getAttribute('data-ad-status');
            const iframe = ins.querySelector('iframe');

            if (status === 'unfilled') {
              slot.remove();              // 미충전 → 박스 제거
              clearInterval(checker);
            } else if (iframe && iframe.offsetHeight > 0) {
              clearInterval(checker);     // 광고 정상 표시 → 그대로 둠
            } else if (tries >= 12) {
              // 약 3초(250ms*12) 지나도 광고(iframe)가 안 생기면
              // 광고차단 프로그램 등으로 못 뜬 것 → 빈 박스 제거
              slot.remove();
              clearInterval(checker);
            }
          }, 250);
        });
      });
    </script>

    <!--
      "Rabbit의 한 끗" 마무리 섹션을 카테고리 색 카드로 감싼다.
      기존 글은 `## Rabbit의 한 끗`(h2)로 쓰므로, 그 h2부터 다음 h2(또는 "더 읽어보기") 전까지를
      하나의 카드(div.takeaway)로 묶는다. 글 본문을 고치지 않아도 자동 적용된다.
      에세이 글(.prose-essay)에는 적용하지 않는다(마무리 소제목 자체가 없음).
    -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const prose = document.querySelector('.prose');
        if (!prose || prose.classList.contains('prose-essay')) return;

        const heads = Array.from(prose.querySelectorAll('h2'));
        const takeawayHead = heads.find((h) => {
          // 공백과 아포스트로피(일반/스마트따옴표 U+2019)를 제거하고 비교 — smartypants 변환 여부 무관하게 매칭
          const t = (h.textContent || '').replace(/[\s'\u2019]/g, '');
          return t.includes('Rabbit의한끗') || t.includes('RabbitsTakeaway');
        });
        if (!takeawayHead) return;

        // 카드로 옮길 노드: 이 h2부터 다음 h2/"더 읽어보기"(strong) 블록 전까지
        const card = document.createElement('div');
        card.className = 'takeaway-card';

        const collected = [];
        let node = takeawayHead;
        while (node) {
          const next = node.nextElementSibling;
          // 다음 h2를 만나면 종료
          if (node !== takeawayHead && node.tagName === 'H2') break;
          // 수평선(마크다운 ---)을 만나면 종료 — "더 읽어보기" 앞 구분선이 카드 안에 딸려 들어가지 않게 함
          if (node.tagName === 'HR') break;
          // "더 읽어보기 / Read more" 문단(strong만 있는 p)을 만나면 종료
          if (node.tagName === 'P') {
            const strong = node.querySelector('strong');
            const txt = (node.textContent || '').replace(/\s/g, '');
            if (strong && (txt.includes('더읽어보기') || txt.includes('Readmore'))) break;
          }
          collected.push(node);
          node = next;
        }
        if (collected.length === 0) return;

        takeawayHead.parentNode.insertBefore(card, takeawayHead);
        collected.forEach((n) => card.appendChild(n));
      });
    </script>

    <!--
      라이트박스: 본문(.prose) 안의 이미지를 클릭하면 확대 팝업으로 보여준다.
      ※ 본문에 광고가 삽입된 뒤(위 스크립트) 동작해야 새로 추가될 이미지가 없으므로 순서 그대로 둔다.
      ※ alt 텍스트를 캡션으로 사용(없으면 캡션 영역 숨김).
    -->
    <div id="lightbox" class="lightbox" hidden>
      <button type="button" class="lightbox-close" aria-label="닫기">✕</button>
      <img class="lightbox-img" src="" alt="" />
      <p class="lightbox-caption"></p>
    </div>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const prose = document.querySelector('.prose');
        const lightbox = document.getElementById('lightbox');
        if (!prose || !lightbox) return;

        const lbImg = lightbox.querySelector('.lightbox-img');
        const lbCaption = lightbox.querySelector('.lightbox-caption');
        const lbClose = lightbox.querySelector('.lightbox-close');
        let lastFocused = null;

        const openLightbox = (img) => {
          lastFocused = document.activeElement;
          lbImg.src = img.currentSrc || img.src;
          lbImg.alt = img.alt || '';
          if (img.alt) {
            lbCaption.textContent = img.alt;
            lbCaption.hidden = false;
          } else {
            lbCaption.textContent = '';
            lbCaption.hidden = true;
          }
          lightbox.hidden = false;
          document.body.style.overflow = 'hidden';
          lbClose.focus();
        };

        const closeLightbox = () => {
          lightbox.hidden = true;
          lbImg.src = '';
          document.body.style.overflow = '';
          if (lastFocused) lastFocused.focus();
        };

        // 본문 안의 이미지를 wrapper로 감싸 클릭 영역을 잡는다.
        // (호버 시 이미지가 살짝 어두워지는 것만으로 클릭 가능함을 알린다 — 별도 아이콘 없음)
        prose.querySelectorAll('img').forEach((img) => {
          img.classList.add('lightbox-trigger');

          const wrap = document.createElement('span');
          wrap.className = 'lightbox-zoom-wrap';
          wrap.tabIndex = 0;
          wrap.setAttribute('role', 'button');
          wrap.setAttribute('aria-label', '이미지 확대');
          img.parentNode.insertBefore(wrap, img);
          wrap.appendChild(img);

          wrap.addEventListener('click', () => openLightbox(img));
          wrap.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              openLightbox(img);
            }
          });
        });

        lbClose.addEventListener('click', closeLightbox);
        lightbox.addEventListener('click', (e) => {
          if (e.target === lightbox) closeLightbox();
        });
        document.addEventListener('keydown', (e) => {
          if (!lightbox.hidden && e.key === 'Escape') closeLightbox();
        });
      });
    </script>
  </article>

  <!-- 사이드바 TOC: 본문 안 [[TOC]] 결과(nav.toc)를 JS로 여기 옮겨 데스크탑에서 sticky로 계속 보이게 한다.
       모바일(폭 좁음)에서는 CSS로 사이드바를 숨기고 본문 원래 위치의 목차를 그대로 보여준다. -->
  <aside class="toc-sidebar" id="toc-sidebar" aria-hidden="true"></aside>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const prose = document.querySelector('.prose');
      const sidebar = document.getElementById('toc-sidebar');
      const sourceToc = prose && prose.querySelector('.toc');
      if (!prose || !sidebar || !sourceToc) return;

      // 목차 카드 하나를 "헤더(아이콘+제목) + 진행바" 구조로 꾸민다.
      // 데스크탑용(사이드바 복제본)과 모바일용(본문 원본) 둘 다 이 함수로 동일하게 꾸며서,
      // 위치만 다를 뿐 헤더·트랙·진행바·스크롤스파이는 완전히 동일하게 동작하게 만든다.
      const decorate = (tocEl) => {
        const wrapTitle = document.createElement('div');
        wrapTitle.className = 'toc-sidebar-head';
        wrapTitle.innerHTML = '<span class="toc-sidebar-icon" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg></span><span>' + (document.documentElement.lang === 'en' ? 'Contents' : '목차') + '</span>';

        const titleEl = tocEl.querySelector('.toc-title');
        if (titleEl) titleEl.remove();

        const progressBar = document.createElement('div');
        progressBar.className = 'toc-sidebar-progress';
        tocEl.querySelector('ul').prepend(progressBar);

        tocEl.prepend(wrapTitle);

        const links = Array.from(tocEl.querySelectorAll('a[href^="#"]'));
        return { links, progressBar };
      };

      // 데스크탑 사이드바용 복제본 — 원본은 모바일용으로 본문에 그대로 둔다.
      const sidebarToc = sourceToc.cloneNode(true);
      sidebarToc.removeAttribute('aria-label');
      sidebar.appendChild(sidebarToc);
      sidebar.removeAttribute('aria-hidden');
      sidebar.classList.add('is-ready');

      const desktop = decorate(sidebarToc);
      const mobile = decorate(sourceToc);

      if (desktop.links.length === 0 && mobile.links.length === 0) return;

      // 두 목차(사이드바/본문) 중 실제로 존재하는 슬러그를 기준으로 heading 목록을 만든다.
      // 두 인스턴스의 링크 순서·슬러그는 항상 동일(같은 [[TOC]] 결과를 복제한 것)하므로
      // desktop 쪽을 기준 삼아도 무방하다.
      const refLinks = desktop.links.length > 0 ? desktop.links : mobile.links;
      const slugOrder = refLinks.map((a) => decodeURIComponent(a.getAttribute('href').slice(1)));

      const headings = slugOrder
        .map((slug) => document.getElementById(slug))
        .filter(Boolean);
      if (headings.length === 0) return;

      const findLink = (instance, slug) =>
        instance.links.find((a) => decodeURIComponent(a.getAttribute('href').slice(1)) === slug);

      let activeSlug = null;
      const setActive = (slug) => {
        if (activeSlug === slug) return;
        [desktop, mobile].forEach((instance) => {
          if (instance.links.length === 0) return;
          const prevLink = activeSlug ? findLink(instance, activeSlug) : null;
          if (prevLink) {
            prevLink.classList.remove('is-active');
            prevLink.closest('li') && prevLink.closest('li').classList.remove('is-active');
          }
          const nextLink = slug ? findLink(instance, slug) : null;
          if (nextLink) {
            nextLink.classList.add('is-active');
            nextLink.closest('li') && nextLink.closest('li').classList.add('is-active');
          }
          const idx = nextLink ? instance.links.indexOf(nextLink) : 0;
          const ratio = instance.links.length <= 1 ? 1 : idx / (instance.links.length - 1);
          instance.progressBar.style.height = Math.round(ratio * 100) + '%';
        });
        activeSlug = slug;
      };

      const visibleSet = new Set();
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) visibleSet.add(entry.target.id);
            else visibleSet.delete(entry.target.id);
          });

          if (visibleSet.size > 0) {
            // 화면에 여러 섹션이 보이면 문서 순서상 가장 앞선(첫) 섹션을 현재 위치로 삼는다.
            const firstVisible = headings.find((h) => visibleSet.has(h.id));
            if (firstVisible) setActive(firstVisible.id);
          } else {
            // 관찰 영역(마진) 안에 걸린 섹션이 없으면, 스크롤 위치보다 위에 있는
            // 마지막 헤딩을 현재 섹션으로 간주한다(빠르게 스크롤해 지나친 경우 대비).
            const scrollY = window.scrollY + window.innerHeight * 0.2;
            let candidate = headings[0];
            for (const h of headings) {
              if (h.getBoundingClientRect().top + window.scrollY <= scrollY) candidate = h;
              else break;
            }
            setActive(candidate.id);
          }
        },
        { rootMargin: '-15% 0px -70% 0px', threshold: 0 }
      );

      headings.forEach((h) => observer.observe(h));
      setActive(headings[0].id);

      // 항목 클릭 시 부드럽게 스크롤(전역 scroll-behavior가 이미 처리하지만 명시적으로 처리).
      [...desktop.links, ...mobile.links].forEach((a) => {
        a.addEventListener('click', (e) => {
          const id = decodeURIComponent(a.getAttribute('href').slice(1));
          const target = document.getElementById(id);
          if (!target) return;
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.pushState(null, '', '#' + id);
        });
      });
    });
  </script>

  <!-- 읽기 진행바 스크립트: article(.post) 기준 스크롤 진행률을 0~100%로 계산 -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const bar = document.querySelector('.reading-progress-bar');
      const article = document.querySelector('.post');
      if (!bar || !article) return;

      let ticking = false;
      const update = () => {
        ticking = false;
        const rect = article.getBoundingClientRect();
        const articleTop = rect.top + window.scrollY;
        const articleHeight = article.offsetHeight;
        const viewportH = window.innerHeight;

        const scrolled = window.scrollY - articleTop + viewportH * 0.4;
        const total = Math.max(articleHeight - viewportH * 0.4, 1);
        const pct = Math.min(100, Math.max(0, (scrolled / total) * 100));
        bar.style.width = pct + '%';
      };

      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(update);
          ticking = true;
        }
      }, { passive: true });
      window.addEventListener('resize', update);
      update();
    });
  </script>

  <style is:global>
    /* 읽기 진행바: 화면 최상단 고정, 헤더보다 위 레이어 */
    .reading-progress {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      height: 3px; background: transparent;
    }
    .reading-progress-bar {
      height: 100%; width: 0%;
      background: var(--primary);
      transition: width 0.1s linear;
    }

    /* 글 페이지는 사이드바를 위해 컨테이너 폭을 넓힌다(다른 페이지의 .wrap 720px은 그대로 유지). */
    .wrap:has(.post-grid) { max-width: 980px; }

    .post-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 240px;
      gap: 2.5rem;
      align-items: start;
    }

    /* sticky 사이드바: 헤더 높이(대략 4.5rem) + 여유 여백만큼 top을 띄워서
       처음 스크롤할 때 카드가 헤더에 바짝 붙지 않게 한다. */
    .toc-sidebar {
      position: sticky;
      top: 5.5rem;
      align-self: start;
      max-height: calc(100vh - 7rem);
      overflow-y: auto;
      margin-top: 2.5rem;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 14px;
      box-shadow: 0 4px 16px rgba(32, 37, 31, 0.06);
      opacity: 0;
      transition: opacity 0.15s;
    }
    .toc-sidebar::-webkit-scrollbar { width: 4px; }
    .toc-sidebar::-webkit-scrollbar-thumb { background: var(--line); border-radius: 4px; }
    .toc-sidebar.is-ready { opacity: 1; }
    .toc-sidebar:empty,
    .toc-sidebar:not(.is-ready) { display: none; }

    /* ===== 목차 카드 공통 스타일: 데스크탑(사이드바)·모바일(본문 원위치) 둘 다 동일하게 적용 =====
       .toc-sidebar .toc = 데스크탑 사이드바 안 복제본 / .prose > .toc = 모바일 본문 원본.
       두 컨텍스트 모두에 같은 헤더·트랙·진행바·원형 인디케이터·스크롤스파이 스타일을 건다. */

    /* 카드 헤더 바(아이콘 + "목차" 타이틀) — 참고 디자인의 toc-header와 동일한 구조 */
    .toc-sidebar-head {
      display: flex; align-items: center; gap: 0.5rem;
      font-weight: 700; font-size: 0.95rem; color: var(--primary);
      padding: 0.9rem 1.2rem;
      border-bottom: 1px solid var(--line);
    }
    .toc-sidebar-icon {
      width: 24px; height: 24px; border-radius: 7px; flex-shrink: 0;
      background: var(--color-bg-soft); color: var(--primary);
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 0.85rem;
    }

    .toc-sidebar .toc,
    .prose > .toc {
      margin: 0; padding: 0; background: #fff; border: 1px solid var(--line);
      border-radius: 14px; box-shadow: 0 4px 16px rgba(32, 37, 31, 0.06); position: relative;
      overflow: hidden;
    }
    .prose > .toc { margin: 2rem 0; }
    .toc-sidebar .toc-hint,
    .prose > .toc .toc-hint { display: none; }
    .toc-sidebar .toc ul,
    .prose > .toc ul { list-style: none; margin: 0; padding: 0.7rem 1.2rem 0.7rem 0; }

    /* 좌측 세로 트랙 + 진행바(참고 디자인의 toc-track/toc-progress).
       트랙(회색 배경선) 위에 진행바(청록, 현재 섹션 비율만큼 채워짐)를 겹쳐 놓는다. */
    .toc-sidebar .toc ul,
    .prose > .toc ul {
      position: relative;
    }
    .toc-sidebar .toc ul::before,
    .prose > .toc ul::before {
      content: '';
      position: absolute; left: 1.2rem; top: 0.35rem; bottom: 0.35rem; width: 2px;
      background: var(--line); border-radius: 2px;
    }
    .toc-sidebar-progress {
      position: absolute; left: 1.2rem; top: 0.35rem; width: 2px;
      background: var(--primary); border-radius: 2px;
      height: 0%; transition: height 0.2s ease;
    }

    .toc-sidebar .toc li,
    .prose > .toc li {
      margin: 0; padding: 0.55rem 1.2rem 0.55rem 2.3rem;
      position: relative;
      font-size: 0.88rem; line-height: 1.45;
    }
    .toc-sidebar .toc li.sub,
    .prose > .toc li.sub { padding-left: 3.1rem; font-size: 0.82em; }

    /* 원형 인디케이터: 빈 원(기본) / 채운 원+은은한 글로우(현재 섹션) */
    .toc-sidebar .toc li::before,
    .prose > .toc li::before {
      content: '';
      position: absolute; left: 0.95rem; top: 1rem;
      width: 9px; height: 9px; border-radius: 50%;
      background: #fff; border: 2px solid var(--line);
      transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
      z-index: 1;
    }
    .toc-sidebar .toc li.sub::before,
    .prose > .toc li.sub::before {
      left: 1.13rem; top: 1.05rem;
      width: 5px; height: 5px; border: none; background: var(--muted);
    }
    .toc-sidebar .toc li.is-active::before,
    .prose > .toc li.is-active::before {
      background: var(--primary); border-color: var(--primary);
      box-shadow: 0 0 0 4px rgba(44, 95, 87, 0.15);
    }
    .toc-sidebar .toc a,
    .prose > .toc a {
      color: var(--muted); text-decoration: none; display: block;
      transition: color 0.15s;
    }
    .toc-sidebar .toc a:hover,
    .prose > .toc a:hover { color: var(--primary); }
    .toc-sidebar .toc a.is-active,
    .prose > .toc a.is-active {
      color: var(--primary); font-weight: 700;
    }
    .toc-sidebar .toc-num,
    .prose > .toc .toc-num {
      color: var(--muted); font-weight: 700; margin-right: 0.4rem;
      font-variant-numeric: tabular-nums; font-size: 0.85em;
    }
    .toc-sidebar .toc a.is-active .toc-num,
    .prose > .toc a.is-active .toc-num { color: var(--primary); }

    /* 데스크탑(사이드바 있음): 본문 안 원본 목차는 숨기고 사이드바 쪽만 보여준다. */
    @media (min-width: 901px) {
      .prose > .toc { display: none; }
    }

    /* 모바일/좁은 화면: 사이드바는 숨기고, 본문 원래 위치의 카드형 목차(스크롤스파이·진행바 포함)를 보여준다 */
    @media (max-width: 900px) {
      .wrap:has(.post-grid) { max-width: 720px; }
      .post-grid { display: block; }
      .toc-sidebar { display: none !important; }
    }
  </style>

  <style>
    .post { padding: 2.5rem 0; }
    .post-meta { display: flex; gap: 0.75rem; align-items: center; font-size: 0.85rem; margin-bottom: 1rem; }
    .cat { color: var(--accent); font-weight: 700; }
    .date { color: var(--muted); }
    .post h1 {
      font-size: 2rem; font-weight: 800; line-height: 1.3; margin: 0 0 0.6rem;
      letter-spacing: -0.03em;
    }
    .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 2rem 0 0.5rem; }
    .mini-map {
      margin: 2rem 0 0;
      padding: 1rem 1.1rem 0.6rem;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #faf8f3;
    }
    .mini-map-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.3rem; }
    .mini-map-label { font-size: 0.85rem; font-weight: 700; color: var(--ink, #2a2a26); }
    .mini-map-all { font-size: 0.8rem; color: var(--primary); text-decoration: none; font-weight: 600; white-space: nowrap; }
    .mini-map-all:hover { text-decoration: underline; }
    .mini-map-svg { width: 100%; max-width: 420px; height: auto; display: block; margin: 0 auto; }
    .mini-map-svg a { cursor: pointer; }
    .mm-label { font-size: 8.5px; fill: #6b6555; }
    .mini-map-svg a:hover .mm-label { fill: var(--primary); font-weight: 700; }
    .mini-map-svg a:hover circle { stroke: var(--primary); }
    .mm-center-label { font-size: 9px; font-weight: 700; fill: var(--ink, #2a2a26); }
    .mini-map-legend {
      display: flex; gap: 14px; flex-wrap: wrap; justify-content: center;
      margin-top: 0.3rem; padding-bottom: 0.6rem;
      font-size: 10.5px; color: #6b6555;
    }
    .mini-map-legend .mm-line { display: inline-block; width: 16px; height: 0; vertical-align: middle; margin-right: 4px; border-top: 1.4px solid #a8a194; }
    .mini-map-legend .mm-line.dashed { border-top-style: dashed; }
    .mini-map-legend .mm-line.thick { border-top-width: 2.2px; border-top-color: #d99441; }
    .post-tags .tag {
      font-size: 0.85rem; color: var(--primary); background: rgba(44,95,87,0.07);
      border: 1px solid rgba(44,95,87,0.15); border-radius: 999px; padding: 0.25rem 0.75rem;
    }
    .subtitle {
      font-size: 1.05rem; color: var(--muted); line-height: 1.6;
      margin: 0 0 1.8rem; font-weight: 400;
    }
    /* 글 끝(푸터 직전) 광고는 아래 여백을 줄여 푸터와 간격을 좁힌다.
       (광고 박스 기본 margin 2.5rem + 푸터 margin-top 4rem이 겹쳐 벌어지는 것 보정) */
    .post :global(.ad-slot.ad-last) { margin-bottom: 0; }

    /* 본문 이미지 확대 아이콘 오버레이 (브라우저 기본 zoom 커서는 쓰지 않음 — 아이콘 하나만 보이게 pointer 사용) */
    .post :global(.prose .lightbox-zoom-wrap) {
      position: relative;
      display: block;
      cursor: pointer;
      border-radius: 8px;
      margin: 1.5rem auto 0.1rem;
      max-width: 100%;
    }
    .post :global(.prose .lightbox-zoom-wrap img) {
      transition: filter 0.15s;
      margin: 0;
      display: block;
    }
    .post :global(.prose .lightbox-zoom-wrap:hover img),
    .post :global(.prose .lightbox-zoom-wrap:focus-visible img) {
      filter: brightness(0.93);
    }
    .post :global(.prose .lightbox-zoom-wrap:focus-visible) {
      outline: 2px solid var(--primary);
      outline-offset: 2px;
    }
  </style>

  <style is:global>
    /* 라이트박스(이미지 확대 팝업) */
    .lightbox {
      position: fixed; inset: 0; z-index: 999;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 0.9rem; padding: 2.5rem 1.25rem;
      background: rgba(32, 37, 31, 0.92);
      cursor: zoom-out;
    }
    .lightbox[hidden] { display: none; }
    .lightbox-img {
      max-width: 100%; max-height: 80vh;
      border-radius: 8px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.4);
      cursor: default;
    }
    .lightbox-caption {
      margin: 0; max-width: 640px;
      color: #f3f0e8; font-size: 0.92rem; line-height: 1.6;
      text-align: center; cursor: default;
    }
    .lightbox-caption[hidden] { display: none; }
    .lightbox-close {
      position: absolute; top: 1.1rem; right: 1.25rem;
      width: 40px; height: 40px;
      display: inline-flex; align-items: center; justify-content: center;
      background: rgba(255,255,255,0.1); border: none; border-radius: 999px;
      color: #fff; font-size: 1.1rem; line-height: 1; cursor: pointer;
      transition: background 0.15s;
    }
    .lightbox-close:hover { background: rgba(255,255,255,0.22); }
    .lightbox-close:focus-visible { outline: 2px solid #fff; outline-offset: 2px; }

    @media (max-width: 640px) {
      .lightbox { padding: 1.5rem 1rem; }
      .lightbox-img { max-height: 72vh; }
      .lightbox-close { top: 0.7rem; right: 0.8rem; width: 36px; height: 36px; }
    }
  </style>
</BaseLayout>

---
const { title, description, lang = 'ko' } = Astro.props;

const nav = {
  ko: { project: 'SAP 프로젝트', operations: 'SAP 실무운영', study: 'SAP 학습자료', about: '소개 & 문의', other: 'English', otherHref: '/en/' },
  en: { project: 'SAP Projects', operations: 'SAP Operations', study: 'SAP Study Notes', about: 'About & Contact', other: '한국어', otherHref: '/' },
};
const t = nav[lang];
const home = lang === 'en' ? '/en/' : '/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://rabbitlogs.com/og-thumbnail.jpg" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://rabbitlogs.com/og-thumbnail.jpg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <a href={home} class="brand"><span class="brand-mark">🐇</span><span class="brand-name">Rabbit Logs</span></a>
        <nav class="nav">
          <a href={`${home}category/project`}>{t.project}</a>
          <a href={`${home}category/operations`}>{t.operations}</a>
          <a href={`${home}category/study`}>{t.study}</a>
          <a href={`${home}about`}>{t.about}</a>
          <a href={t.otherHref} class="lang-switch">{t.other}</a>
        </nav>
      </div>
    </header>

    <main class="wrap"><slot /></main>

    <footer class="site-footer"><div class="wrap"><p>🐇 Hop! Log! Repeat! · © 2026 Rabbit Logs</p></div></footer>

    <style is:global>
      :root {
        --paper: #faf8f3; --ink: #20251f; --primary: #2c5f57; --accent: #d99441;
        --muted: #7c7a72; --line: #e3dfd4; --color-bg-soft: #f3f0e8;
        --font-body: 'Pretendard', -apple-system, system-ui, sans-serif;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; background: var(--paper); color: var(--ink); font-family: var(--font-body); font-size: 17px; line-height: 1.8; -webkit-font-smoothing: antialiased; }
      .wrap { max-width: 720px; margin: 0 auto; padding: 0 1.25rem; }

      .site-header { border-bottom: 1px solid var(--line); }
      .header-inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1rem 0; flex-wrap: wrap; }
      .brand { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: var(--ink); }
      .brand-logo { height: 40px; width: auto; display: block; }
      .brand-name { font-weight: 800; font-size: 1.3rem; letter-spacing: -0.02em; }
      .nav { display: flex; gap: 1.1rem; align-items: center; flex-wrap: wrap; }
      .nav a { text-decoration: none; color: var(--muted); font-size: 0.9rem; font-weight: 500; }
      .nav a:hover { color: var(--primary); }
      .lang-switch { border: 1px solid var(--line); border-radius: 999px; padding: 0.15rem 0.7rem; color: var(--primary) !important; }

      .site-footer { margin-top: 4rem; border-top: 1px solid var(--line); padding: 2rem 0; color: var(--muted); font-size: 0.85rem; text-align: center; }

      /* ── 본문(prose) — 전체 Pretendard, 굵기로 위계 ── */
      .prose { font-size: 17px; line-height: 1.85; }
      .prose p { margin: 1.15rem 0; }
      .prose h2 { font-weight: 700; font-size: 1.5rem; margin-top: 2.6rem; margin-bottom: 0.8rem; line-height: 1.35; scroll-margin-top: 1.5rem; letter-spacing: -0.01em; }
      .prose h3 { font-weight: 600; font-size: 1.2rem; margin-top: 1.8rem; margin-bottom: 0.5rem; scroll-margin-top: 1.5rem; color: var(--primary); }
      .prose h2 a, .prose h3 a { color: inherit; text-decoration: none; }
      .prose strong { font-weight: 700; }
      .prose strong.key { color: var(--primary); font-weight: 700; }

      /* 목차 */
      .prose .toc { margin: 2rem 0; padding: 1.1rem 1.4rem; background: var(--color-bg-soft); border: 1px solid var(--line); border-radius: 10px; }
      .prose .toc-title { margin: 0 0 0.6rem; font-weight: 700; font-size: 0.95rem; color: var(--primary); }
      .prose .toc ul { margin: 0; padding-left: 1.1rem; }
      .prose .toc li { margin: 0.25rem 0; font-size: 0.92rem; line-height: 1.5; }
      .prose .toc li.sub { padding-left: 0.9rem; list-style: circle; }
      .prose .toc a { color: var(--ink); text-decoration: none; }
      .prose .toc a:hover { color: var(--accent); text-decoration: underline; }

      .prose mark.hl { background: #fdebc8; color: inherit; padding: 0.05em 0.25em; border-radius: 3px; }
      .prose code { background: #f0eee7; color: #c0392b; padding: 0.12em 0.4em; border-radius: 4px; font-size: 0.92em; font-family: ui-monospace, monospace; }
      .prose blockquote { margin: 1.6rem 0; padding: 1rem 1.2rem; background: var(--color-bg-soft); border-left: 4px solid var(--accent); border-radius: 0 8px 8px 0; }
      .prose blockquote p { margin: 0.4rem 0; }
      .prose blockquote p:first-child { margin-top: 0; }
      .prose blockquote p:last-child { margin-bottom: 0; }
      .prose ul, .prose ol { padding-left: 1.4rem; }
      .prose li { margin: 0.4rem 0; }
      .prose img { max-width: 100%; border-radius: 8px; display: block; margin: 1.5rem auto 0.4rem; }

      /* 이미지 캡션 (이미지 바로 뒤 기울임 줄) */
      .prose em { color: var(--muted); }
      .prose p:has(img) { margin-bottom: 0.3rem; text-align: center; }
      .prose p:has(img) + p > em:only-child {
        display: block; text-align: center; font-size: 0.88rem;
        color: var(--muted); margin-top: 0.2rem;
      }
      .prose a { color: var(--primary); }

      /* 표 — 헤더 칸 구분(밝은 세로선) + 또렷한 테두리 */
      .prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.95rem; border: 1px solid var(--primary); border-radius: 8px; overflow: hidden; }
      .prose th, .prose td { padding: 0.6rem 0.85rem; text-align: left; }
      .prose td { border: 1px solid #d8d2c4; }
      .prose thead th { background: var(--primary); color: #fff; font-weight: 700; border-right: 1px solid rgba(255,255,255,0.35); }
      .prose thead th:last-child { border-right: none; }
      .prose tbody tr:nth-child(even) { background: rgba(44, 95, 87, 0.04); }
      .prose tbody tr:hover { background: rgba(217, 148, 65, 0.08); }

      @media (max-width: 640px) { body { font-size: 16px; } .prose { font-size: 16px; } }
    </style>
  </body>
</html>

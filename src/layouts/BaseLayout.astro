---
import Search from '../components/Search.astro';
const { title, description, lang = 'ko', showAds = false } = Astro.props;

const nav = {
  ko: {
    project: 'SAP 프로젝트', projectShort: '프로젝트',
    operations: 'SAP 실무운영', operationsShort: '실무운영',
    study: 'SAP 학습자료', studyShort: '학습자료',
    stats: '통계·데이터', statsShort: '통계·데이터',
    about: '소개 & 문의', other: 'EN', otherHref: '/en/', privacy: '개인정보처리방침', terms: '이용약관',
  },
  en: {
    project: 'SAP Projects', projectShort: 'Projects',
    operations: 'SAP Operations', operationsShort: 'Operations',
    study: 'SAP Study Notes', studyShort: 'Study Notes',
    stats: 'Stats & Data', statsShort: 'Stats & Data',
    about: 'About & Contact', other: 'KO', otherHref: '/', privacy: 'Privacy Policy', terms: 'Terms of Use',
  },
};
const t = nav[lang];
const home = lang === 'en' ? '/en/' : '/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="naver-site-verification" content="5ae106a19220bcd3114005c35125285f1c4e4b70" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="alternate" type="application/rss+xml" title="Rabbit Logs RSS" href="/rss.xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://rabbitlogs.com/og-thumbnail.jpg" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://rabbitlogs.com/og-thumbnail.jpg" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <!-- 다이나믹 서브셋: 페이지에 실제 쓰인 글자만 받아온다 (9개 굵기 전체 3.8MB → 대폭 절감) -->
    <!-- 렌더 비차단 로드: 첫 화면은 시스템 폰트로 즉시 그리고, Pretendard는 받으면 swap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard-dynamic-subset.min.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard-dynamic-subset.min.css" /></noscript>
    {showAds && (
      <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9488002130804570" crossorigin="anonymous"></script>
    )}
    <!-- Cloudflare Web Analytics -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "ace324d6aeba4980a4afb29b4666464f"}'></script>
    <!-- End Cloudflare Web Analytics -->
    <!-- 페이지별 추가 head 태그(예: JSON-LD 구조화 데이터) -->
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <a href={home} class="brand"><img src="/rabbit-logo.webp" alt="" class="brand-logo" width="69" height="80" /><span class="brand-name">Rabbit Logs</span></a>
        <div class="header-actions">
          <a href="/map" class="map-btn" aria-label="글 지도">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="6" cy="6" r="2.6"></circle>
              <circle cx="18" cy="7" r="2.6"></circle>
              <circle cx="7" cy="18" r="2.6"></circle>
              <circle cx="17" cy="17" r="2.6"></circle>
              <line x1="8.3" y1="7.3" x2="15.7" y2="6.6"></line>
              <line x1="7.5" y1="8.4" x2="7.3" y2="15.5"></line>
              <line x1="9.2" y1="17.4" x2="14.8" y2="16.6"></line>
              <line x1="17.7" y1="9.5" x2="17.2" y2="14.5"></line>
            </svg>
          </a>
          <Search lang={lang} />
          <a href={t.otherHref} class="lang-switch">{t.other}</a>
          <a href="/rss.xml" class="rss-btn" aria-label="RSS 피드">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 11a9 9 0 0 1 9 9"></path>
              <path d="M4 4a16 16 0 0 1 16 16"></path>
              <circle cx="5" cy="19" r="1.4" fill="currentColor" stroke="none"></circle>
            </svg>
          </a>
        </div>
        <nav class="nav">
          <a href={`${home}category/project`}><span class="lbl-full">{t.project}</span><span class="lbl-short">{t.projectShort}</span></a>
          <a href={`${home}category/operations`}><span class="lbl-full">{t.operations}</span><span class="lbl-short">{t.operationsShort}</span></a>
          <a href={`${home}category/study`}><span class="lbl-full">{t.study}</span><span class="lbl-short">{t.studyShort}</span></a>
          <a href={`${home}category/stats`}><span class="lbl-full">{t.stats}</span><span class="lbl-short">{t.statsShort}</span></a>
          <a href={`${home}about`}>{t.about}</a>
        </nav>
      </div>
    </header>

    <main class="wrap"><slot /></main>

    <footer class="site-footer"><div class="wrap">
      <nav class="footer-links">
        <a href={`${home}about`}>{t.about}</a>
        <a href={`${home}privacy`}>{t.privacy}</a>
        <a href={`${home}terms`}>{t.terms}</a>
      </nav>
      <p>Hop! Log! Repeat! · © 2025 Rabbit Logs</p>
    </div></footer>

    <style is:global>
      :root {
        --paper: #faf8f3; --ink: #20251f; --primary: #2c5f57; --accent: #93642c;
        --muted: #696760; --line: #e3dfd4; --color-bg-soft: #f3f0e8;
        --font-body: 'Pretendard', -apple-system, system-ui, sans-serif;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; background: var(--paper); color: var(--ink); font-family: var(--font-body); font-size: 17px; line-height: 1.8; -webkit-font-smoothing: antialiased; }
      .wrap { max-width: 720px; margin: 0 auto; padding: 0 1.25rem; }

      .site-header { border-bottom: 1px solid var(--line); }
      .header-inner { display: flex; align-items: center; gap: 1rem; padding: 1rem 0 0.4rem; flex-wrap: wrap; }
      .brand { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: var(--ink); margin-right: auto; order: 1; }
      .brand-logo { height: 40px; width: auto; display: block; }
      .brand-name { font-weight: 800; font-size: 1.3rem; letter-spacing: -0.02em; }
      .header-actions { display: flex; align-items: center; gap: 0.5rem; order: 2; }
      .map-btn, .rss-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; padding: 0;
        background: none; border: none; cursor: pointer;
        color: var(--primary); border-radius: 999px;
        transition: background 0.15s;
      }
      .map-btn:hover, .rss-btn:hover { background: rgba(44,95,87,0.08); }
      .lang-switch { border: none; border-radius: 999px; padding: 0.15rem 0.7rem; color: var(--primary) !important; font-size: 0.85rem; font-weight: 600; text-decoration: none; transition: background 0.15s; }
      .lang-switch:hover { background: rgba(44,95,87,0.08); }

      /* 카테고리 nav는 데스크탑에서도 항상 둘째 줄(지도·검색·언어토글은 첫 줄 유지) */
      .nav {
        order: 3; flex: 1 0 100%;
        display: flex; gap: 1.1rem; align-items: center;
        justify-content: flex-end;
        padding-top: 0.3rem;
      }
      .nav a { text-decoration: none; color: var(--muted); font-size: 0.9rem; font-weight: 500; white-space: nowrap; }
      .nav a:hover { color: var(--primary); }
      .lbl-short { display: none; }

      /* 모바일: 카테고리 라벨에서 'SAP' 접두어 생략(짧은 라벨), 한 줄에 균등 배분 */
      @media (max-width: 640px) {
        .header-inner { gap: 0.6rem 0.5rem; }
        .brand { margin-left: 0.5rem; }
        .lang-switch { margin-right: 0.5rem; }
        .header-actions { margin-right: 0.5rem; }
        .nav { justify-content: space-between; gap: 0.3rem; }
        .nav a { font-size: 0.8rem; flex: 1; text-align: center; }
        .lbl-full { display: none; }
        .lbl-short { display: inline; }
      }

      .site-footer { margin-top: 2rem; border-top: 1px solid var(--line); padding: 2rem 0; color: var(--muted); font-size: 0.85rem; text-align: center; }
      .footer-links { display: flex; gap: 1.2rem; justify-content: center; flex-wrap: wrap; margin-bottom: 0.9rem; }
      .footer-links a { color: var(--muted); text-decoration: none; font-weight: 500; }
      .footer-links a:hover { color: var(--primary); }

      /* ── 본문(prose) — 전체 Pretendard, 굵기로 위계 ── */
      .prose { font-size: 17px; line-height: 1.85; }
      .prose p { margin: 1.15rem 0; }
      .prose h2 { font-weight: 700; font-size: 1.5rem; margin-top: 2.6rem; margin-bottom: 0.8rem; line-height: 1.35; scroll-margin-top: 1.5rem; letter-spacing: -0.01em; }
      .prose h3 { font-weight: 600; font-size: 1.2rem; margin-top: 1.8rem; margin-bottom: 0.5rem; scroll-margin-top: 1.5rem; color: var(--primary); }
      .prose h2 a, .prose h3 a { color: inherit; text-decoration: none; }
      .prose strong { font-weight: 700; }
      .prose strong.key { color: var(--primary); font-weight: 700; }

      /* 목차 */
      .prose .toc { margin: 2rem 0; padding: 1.1rem 1.4rem; background: var(--color-bg-soft); border: 1px solid var(--line); border-radius: 10px; }
      .prose .toc-title { margin: 0 0 0.7rem; font-weight: 700; font-size: 1em; color: var(--primary); }
      .prose .toc ul { margin: 0; padding-left: 1.2rem; }
      .prose .toc li { margin: 0.35rem 0; font-size: 1em; line-height: 1.6; }
      .prose .toc li.sub { margin-left: 1.3rem; list-style: circle; }
      .prose .toc a { color: var(--ink); text-decoration: none; }
      .prose .toc a:hover { color: var(--accent); text-decoration: underline; }

      .prose mark.hl { background: #fdebc8; color: inherit; padding: 0.05em 0.25em; border-radius: 3px; }
      .prose code { background: #f0eee7; color: #c0392b; padding: 0.12em 0.4em; border-radius: 4px; font-size: 0.92em; font-family: ui-monospace, monospace; }
      .prose blockquote { margin: 1.6rem 0; padding: 1rem 1.2rem; background: var(--color-bg-soft); border-left: 4px solid var(--accent); border-radius: 0 8px 8px 0; }
      .prose blockquote p { margin: 0.4rem 0; }
      .prose blockquote p:first-child { margin-top: 0; }
      .prose blockquote p:last-child { margin-bottom: 0; }
      .prose ul, .prose ol { padding-left: 1.4rem; }
      .prose li { margin: 0.4rem 0; }
      .prose img { max-width: 100%; height: auto; border-radius: 8px; display: block; margin: 1.5rem auto 0; }

      /* 캡션 (이미지/표 뒤 기울임 한 줄) — 그림·표 캡션 크기·정렬·간격 완전 통일 */
      .prose em { color: var(--muted); }

      /* 이미지가 든 문단 자체를 가운데 정렬 (이미지+캡션이 한 문단이어도 적용) */
      .prose p:has(img) { margin: 1.5rem 0 1.6rem; text-align: center; }
      .prose p:has(img) img { margin-bottom: 0.1rem; }

      /* 이미지 문단 안의 캡션(em) + 표 다음 문단의 캡션(em) → 같은 스타일 */
      .prose p:has(img) em,
      .prose p:has(img) + p:has(> em:only-child) em,
      .prose table + p:has(> em:only-child) em {
        display: inline-block;
        font-size: 0.88rem;
        color: var(--muted);
      }
      /* 별도 문단으로 떨어진 캡션의 간격/정렬 */
      .prose p:has(img) + p:has(> em:only-child),
      .prose table + p:has(> em:only-child) {
        margin: 0.4rem 0 1.6rem;
        text-align: center;
      }
      .prose a { color: var(--primary); }

      /* 표 — 안쪽 칸 구분선만 (바깥 좌우 세로줄 없음), 헤더는 밝은 칸 구분선 */
      .prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0 0; font-size: 0.95rem; }
      .prose th, .prose td { padding: 0.6rem 0.85rem; text-align: left; }
      /* 세로 구분선: 첫 칸 빼고 모든 칸 왼쪽에 선 (공백 노드 영향 없는 방식) */
      .prose tr th:not(:first-child),
      .prose tr td:not(:first-child) { border-left: 1px solid #d8d2c4; }
      /* 가로 구분선: 모든 행 아래에 선 (마지막 행 포함) */
      .prose tbody tr { border-bottom: 1px solid #d8d2c4; }
      /* 헤더 */
      .prose thead th { background: var(--primary); color: #fff; font-weight: 700; }
      .prose thead tr th:not(:first-child) { border-left: 1px solid rgba(255,255,255,0.4); }
      /* 줄무늬 + 호버 */
      .prose tbody tr:nth-child(even) { background: rgba(44, 95, 87, 0.04); }
      .prose tbody tr:hover { background: rgba(217, 148, 65, 0.08); }

      @media (max-width: 640px) { body { font-size: 16px; } .prose { font-size: 16px; } }
    </style>
  </body>
</html>

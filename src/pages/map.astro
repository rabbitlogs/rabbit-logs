---
import fs from 'node:fs';
import path from 'node:path';
import yaml from 'js-yaml';
import BaseLayout from '../layouts/BaseLayout.astro';

// book-index.yaml은 빌드 타임에만 읽는다 (클라이언트로는 가공된 JSON만 내려감)
const yamlPath = path.resolve('./src/data/book-index.yaml');
const raw = fs.readFileSync(yamlPath, 'utf-8');
const allEntries = yaml.load(raw);

// 블로그엔 리빌딩 완료(rebuilt)된 글만 존재하므로, 지도에도 그만 표시한다
const rebuilt = allEntries.filter((e) => e.status === 'rebuilt');
const rebuiltIds = new Set(rebuilt.map((e) => e.slug));

const catColor = { project: '#2c5f57', operations: '#3b6ea5', study: '#d99441' };

// 카테고리급 1차 태그는 거의 모든 글에 붙어 그래프를 지저분하게 만들어 제외
const skipTags = new Set(['SAP프로젝트', 'SAP실무운영', 'SAP학습자료']);

const postNodes = rebuilt.map((e) => ({
  id: e.slug,
  title: e.title,
  category: e.category,
  tags: (e.tags || []).filter((t) => !skipTags.has(t)),
  isTag: false,
}));

const tagCount = {};
postNodes.forEach((n) => n.tags.forEach((t) => (tagCount[t] = (tagCount[t] || 0) + 1)));
const tagNodes = Object.keys(tagCount).map((t) => ({ id: '#' + t, title: t, isTag: true }));

const postEdges = [];
rebuilt.forEach((e) => {
  const rel = e.relations || {};
  (rel.prerequisite || []).forEach((t) => {
    if (rebuiltIds.has(t)) postEdges.push({ s: t, t: e.slug, type: 'prerequisite' });
  });
  (rel.related || []).forEach((t) => {
    if (rebuiltIds.has(t)) postEdges.push({ s: e.slug, t, type: 'related' });
  });
  (rel.deepens || []).forEach((t) => {
    if (rebuiltIds.has(t)) postEdges.push({ s: e.slug, t, type: 'deepens' });
  });
});
// related는 양방향 중복 제거
const seen = new Set();
const dedupPostEdges = postEdges.filter((e) => {
  if (e.type !== 'related') return true;
  const key = [e.s, e.t].sort().join('|');
  if (seen.has(key)) return false;
  seen.add(key);
  return true;
});

const tagEdges = [];
postNodes.forEach((n) => n.tags.forEach((t) => tagEdges.push({ s: n.id, t: '#' + t, type: 'tag' })));

const graphData = {
  nodes: [...postNodes, ...tagNodes],
  edges: [...dedupPostEdges, ...tagEdges],
  catColor,
};
const graphJson = JSON.stringify(graphData);
---

<BaseLayout title="글 지도 — Rabbit Logs" description="레스토랑으로 배우는 SAP, 글들의 관계와 태그를 한눈에 보는 지도" lang="ko">
  <section style="padding-top: 1.2rem;">
    <div id="header-row">
      <h1 style="font-size: 1.7rem; margin: 0;">🐰 글 지도</h1>
      <div id="toolbar">
        <span class="chip active" data-cat="all">전체</span>
        <span class="chip" data-cat="project"><i class="cdot" style="background:#2c5f57"></i>project</span>
        <span class="chip" data-cat="operations"><i class="cdot" style="background:#3b6ea5"></i>operations</span>
        <span class="chip" data-cat="study"><i class="cdot" style="background:#d99441"></i>study</span>
        <span class="chip" id="tag-toggle">+ 태그</span>
      </div>
    </div>

    <div id="legend">
      <span><i class="line solid"></i> 선행</span>
      <span><i class="line dashed"></i> 관련</span>
      <span><i class="line thick"></i> 심화</span>
      <span>🖱️ 더블클릭: 글로 이동</span>
    </div>

    <div id="stage">
      <svg id="graph-svg"></svg>
      <div id="tooltip"></div>
      <div id="panel" hidden></div>
    </div>
  </section>

  <script type="application/json" id="graph-data" set:html={graphJson} />
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
  <script is:inline>
    (function () {
      function showErr(msg) {
        var p = document.getElementById('panel');
        if (p) { p.hidden = false; p.style.color = '#b00'; p.textContent = '⚠ ' + msg; }
        console.error('[map] ' + msg);
      }
      function boot() {
        if (typeof d3 === 'undefined') { showErr('d3 로드 실패 — 새로고침하거나 광고차단 확장을 꺼보세요'); return; }
        const RAW = JSON.parse(document.getElementById('graph-data').textContent);
    const catColor = RAW.catColor;
    const allNodes = RAW.nodes;
    const allEdges = RAW.edges;
    const allNodesById = {};
    allNodes.forEach((n) => (allNodesById[n.id] = n));

    const postNodes = RAW.nodes.filter((n) => !n.isTag);
    const postEdges = RAW.edges.filter((e) => e.type !== 'tag');

    const svg = d3.select('#graph-svg');
    const stage = document.getElementById('stage');
    let width = stage.clientWidth,
      height = stage.clientHeight;
    const g = svg.append('g');
    svg.call(d3.zoom().scaleExtent([0.2, 3]).on('zoom', (ev) => g.attr('transform', ev.transform)));

    svg
      .append('defs')
      .append('marker')
      .attr('id', 'arrow')
      .attr('viewBox', '0 -4 8 8')
      .attr('refX', 17)
      .attr('refY', 0)
      .attr('markerWidth', 4)
      .attr('markerHeight', 4)
      .attr('orient', 'auto')
      .append('path')
      .attr('d', 'M0,-4L8,0L0,4')
      .attr('fill', '#9a9486');

    const edgeStyle = {
      prerequisite: { dash: 'none', width: 1.1, color: '#9a9486', arrow: true },
      related: { dash: '3,3', width: 0.8, color: '#cfc9b9', arrow: false },
      deepens: { dash: 'none', width: 1.8, color: '#d99441', arrow: false },
      tag: { dash: '1,3', width: 0.7, color: '#e8d8b8', arrow: false },
    };

    const tooltip = d3.select('#tooltip');
    let active = null;
    let activeCat = 'all';
    let showTags = false;
    let sim, node, link, label, curNodes, curEdges, curNodesById;

    function buildGraph(withTags) {
      showTags = withTags;
      active = null;
      g.selectAll('*').remove();
      if (sim) sim.stop();

      curNodes = withTags ? RAW.nodes.map((n) => ({ ...n })) : postNodes.map((n) => ({ ...n }));
      curEdges = withTags ? RAW.edges : postEdges;
      curNodesById = {};
      curNodes.forEach((n) => (curNodesById[n.id] = n));

      const linkObjs = curEdges.map((e) => ({ source: e.s, target: e.t, type: e.type }));

      sim = d3
        .forceSimulation(curNodes)
        .force(
          'link',
          d3
            .forceLink(linkObjs)
            .id((d) => d.id)
            .distance((d) => (d.type === 'tag' ? 42 : d.type === 'prerequisite' ? 78 : 95))
            .strength((d) => (d.type === 'tag' ? 0.3 : 0.55))
        )
        .force('charge', d3.forceManyBody().strength((d) => (d.isTag ? -60 : withTags ? -200 : -260)))
        .force('center', d3.forceCenter(width / 2, height / 2))
        .force('collide', d3.forceCollide().radius((d) => (d.isTag ? 14 : 26)))
        .force('x', d3.forceX(width / 2).strength(0.12))
        .force('y', d3.forceY(height / 2).strength(0.14));

      link = g
        .append('g')
        .selectAll('line')
        .data(linkObjs)
        .join('line')
        .attr('stroke', (d) => edgeStyle[d.type].color)
        .attr('stroke-width', (d) => edgeStyle[d.type].width)
        .attr('stroke-dasharray', (d) => edgeStyle[d.type].dash)
        .attr('marker-end', (d) => (edgeStyle[d.type].arrow ? 'url(#arrow)' : null));

      node = g
        .append('g')
        .selectAll('.n')
        .data(curNodes)
        .join('path')
        .attr('class', 'n node')
        .attr('d', (d) => (d.isTag ? d3.symbol().type(d3.symbolDiamond).size(60)() : d3.symbol().type(d3.symbolCircle).size(260)()))
        .attr('fill', (d) => (d.isTag ? '#d99441' : catColor[d.category]))
        .attr('fill-opacity', (d) => (d.isTag ? 0.55 : 1))
        .attr('stroke', (d) => (d.isTag ? '#b8763a' : '#fff'))
        .attr('stroke-width', (d) => (d.isTag ? 1 : 1.5))
        .style('cursor', 'pointer')
        .call(drag(sim));

      label = g
        .append('g')
        .selectAll('text')
        .data(curNodes)
        .join('text')
        .attr('class', (d) => (d.isTag ? 'tag-label' : 'node-label'))
        .attr('dx', (d) => (d.isTag ? 8 : 12))
        .attr('dy', 4)
        .text((d) => (d.isTag ? d.title.replace(/^SAP/, '') : d.title.length > 14 ? d.title.slice(0, 14) + '…' : d.title));

      node
        .on('mouseenter', (ev, d) => {
          tooltip
            .style('opacity', 1)
            .html(d.isTag ? `#${d.title}` : d.title)
            .style('left', ev.offsetX + 14 + 'px')
            .style('top', ev.offsetY + 10 + 'px');
        })
        .on('mouseleave', () => tooltip.style('opacity', 0));

      let clickTimer = null;
      node.on('click', (ev, d) => {
        ev.stopPropagation();
        if (clickTimer) {
          clearTimeout(clickTimer);
          clickTimer = null;
          return;
        }
        clickTimer = setTimeout(() => {
          active = active === d.id ? null : d.id;
          applyFilters();
          clickTimer = null;
        }, 220);
      });

      node.on('dblclick', (ev, d) => {
        ev.stopPropagation();
        if (clickTimer) {
          clearTimeout(clickTimer);
          clickTimer = null;
        }
        if (!d.isTag) window.location.href = `/blog/${d.id}`;
      });

      sim.on('tick', () => {
        link
          .attr('x1', (d) => d.source.x)
          .attr('y1', (d) => d.source.y)
          .attr('x2', (d) => d.target.x)
          .attr('y2', (d) => d.target.y);
        node.attr('transform', (d) => `translate(${d.x},${d.y})`);
        label.attr('x', (d) => d.x).attr('y', (d) => d.y);
      });

      sim.alpha(1).restart();
      applyFilters();
    }

    svg.on('click', () => {
      active = null;
      applyFilters();
    });

    document.querySelectorAll('.chip[data-cat]').forEach((chip) => {
      chip.addEventListener('click', () => {
        document.querySelectorAll('.chip[data-cat]').forEach((c) => c.classList.remove('active'));
        chip.classList.add('active');
        activeCat = chip.dataset.cat;
        active = null;
        applyFilters();
      });
    });

    document.getElementById('tag-toggle').addEventListener('click', (ev) => {
      const next = !showTags;
      ev.currentTarget.textContent = next ? '− 태그' : '+ 태그';
      ev.currentTarget.classList.toggle('active', next);
      buildGraph(next);
    });

    function connected(id) {
      const s = new Set([id]);
      curEdges.forEach((e) => {
        if (e.s === id) s.add(e.t);
        if (e.t === id) s.add(e.s);
      });
      return s;
    }

    function applyFilters() {
      const catOk = (d) => activeCat === 'all' || d.isTag || d.category === activeCat;
      const focusSet = active ? connected(active) : null;
      const hide = (d) => !catOk(d) || (focusSet && !focusSet.has(d.id));

      node.classed('dim', hide);
      label.classed('dim', hide);
      link
        .style('display', (d) => {
          // 관련(related) 선은 평소 숨김 — 노드가 선택됐고 그 노드에 연결될 때만 표시
          if (d.type === 'related') {
            const sId = d.source.id || d.source;
            const tId = d.target.id || d.target;
            if (!active) return 'none';
            if (!(sId === active || tId === active)) return 'none';
          }
          return null;
        })
        .classed('dim', (d) => {
          const sId = d.source.id || d.source;
          const tId = d.target.id || d.target;
          if (focusSet) return !(sId === active || tId === active);
          const sNode = curNodesById[sId];
          const tNode = curNodesById[tId];
          return !catOk(sNode) || !catOk(tNode);
        });

      // 보이는 노드는 중앙으로 끌어모으고, 숨겨진 노드는 약하게 밀어내 변화를 체감시킴
      const visible = (d) => !hide(d);
      sim.force('x', d3.forceX(width / 2).strength((d) => (visible(d) ? 0.2 : 0.02)));
      sim.force('y', d3.forceY(height / 2).strength((d) => (visible(d) ? 0.22 : 0.02)));
      sim.alpha(0.5).restart();
    }

    function drag(simulation) {
      function started(ev, d) {
        if (!ev.active) simulation.alphaTarget(0.2).restart();
        d.fx = d.x;
        d.fy = d.y;
      }
      function dragged(ev, d) {
        d.fx = ev.x;
        d.fy = ev.y;
      }
      function ended(ev, d) {
        if (!ev.active) simulation.alphaTarget(0);
        d.fx = null;
        d.fy = null;
      }
      return d3.drag().on('start', started).on('drag', dragged).on('end', ended);
    }

    buildGraph(false);

    window.addEventListener('resize', () => {
      width = stage.clientWidth;
      height = stage.clientHeight;
      sim.force('center', d3.forceCenter(width / 2, height / 2));
      sim.alpha(0.3).restart();
    });
      } // boot 끝

      // d3 로드 대기 후 부팅 (DOM 준비도 함께 보장)
      var tries = 0;
      function waitAndBoot() {
        var domReady = document.readyState !== 'loading';
        if (typeof d3 !== 'undefined' && domReady) { boot(); return; }
        if (tries++ < 80) { setTimeout(waitAndBoot, 50); return; }
        boot(); // 마지막 시도 (에러 메시지 목적)
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', waitAndBoot);
      } else {
        waitAndBoot();
      }
    })();
  </script>

  <style>
    #header-row {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 0.6rem;
    }
    #legend {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      font-size: 11.5px;
      color: #6b6555;
      margin-bottom: 0.8rem;
    }
    #legend i.line {
      display: inline-block;
      width: 20px;
      height: 0;
      vertical-align: middle;
      margin-right: 4px;
      border-top: 2px solid #9a9486;
    }
    #legend i.line.dashed {
      border-top: 2px dashed #9a9486;
    }
    #legend i.line.thick {
      border-top: 3px solid #d99441;
    }
    #toolbar {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
    }
    .chip {
      border: 1px solid #d8d2c4;
      border-radius: 20px;
      padding: 4px 12px;
      cursor: pointer;
      background: #fff;
      color: #6b6555;
      font-size: 12px;
      user-select: none;
    }
    .chip .cdot {
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      margin-right: 5px;
      vertical-align: middle;
    }
    .chip.active {
      background: #2c5f57;
      color: #fff;
      border-color: #2c5f57;
    }
    #stage {
      position: relative;
      width: 100vw;
      margin-left: 50%;
      transform: translateX(-50%);
      height: 78vh;
      min-height: 520px;
      border-top: 1px solid #d8d2c4;
      border-bottom: 1px solid #d8d2c4;
      background: #faf8f3;
      overflow: hidden;
    }
    #graph-svg {
      width: 100%;
      height: 100%;
      display: block;
    }
    .node-label {
      font-size: 8px;
      fill: #2a2a26;
      pointer-events: none;
    }
    .tag-label {
      font-size: 7px;
      fill: #93642c;
      pointer-events: none;
    }
    .dim {
      opacity: 0.06 !important;
    }
    #tooltip {
      position: absolute;
      pointer-events: none;
      background: #2a2a26;
      color: #fff;
      padding: 8px 10px;
      border-radius: 6px;
      font-size: 11.5px;
      max-width: 240px;
      opacity: 0;
      transition: opacity 0.12s;
      line-height: 1.4;
      z-index: 10;
    }
    #tooltip b {
      color: #d99441;
      display: block;
      margin-bottom: 2px;
    }
    #tooltip .tagline {
      color: #cfd0c8;
      font-size: 10px;
    }
    #panel {
      position: absolute;
      bottom: 12px;
      left: 12px;
      background: #fff;
      border: 1px solid #d8d2c4;
      border-radius: 10px;
      padding: 8px 11px;
      font-size: 10.5px;
      max-width: 230px;
      color: #6b6555;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    }
  </style>
</BaseLayout>

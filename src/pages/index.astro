---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import { getThumbnail } from '../lib/thumbnail';

// content/blog/ko/ 안의 글만 가져오기
const allPosts = (await getCollection('blog'))
  .filter((p) => p.id.startsWith('ko/'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const posts = allPosts.slice(0, 6);

// 카테고리 둘러보기: 카테고리별 개수 + 대표 글(최신 글) 썸네일
const CATEGORY_META = {
  project: { label: 'SAP 프로젝트', color: '#2c5f57', blurb: '구축부터 안정화까지의 기록' },
  operations: { label: 'SAP 실무운영', color: '#3b6ea5', blurb: '현장에서 부딪히는 실무 팁' },
  study: { label: 'SAP 학습자료', color: '#d99441', blurb: '개념을 차근차근 정리' },
  stats: { label: '통계·데이터', color: '#a8516e', blurb: '데이터로 넓혀가는 여정' },
};

const categoryCards = Object.entries(CATEGORY_META).map(([cat, meta]) => {
  const catPosts = allPosts.filter((p) => p.data.category === cat);
  const latest = catPosts[0];
  return {
    cat,
    ...meta,
    count: catPosts.length,
    href: `/category/${cat}`,
    thumbnail: latest ? getThumbnail(latest) : null,
  };
});
---

<BaseLayout
  title="Rabbit Logs — SAP PP·PI 구축과 운영 기록"
  description="코드는 몰라도, 프로세스는 잘 아는 사람. 생산 PI·SAP PP 구축과 안정화, 현업의 SAP 실무 기록."
  lang="ko"
>
  <section class="hero">
    <div class="hero-img"><img src="/images/hero-rabbit.webp" alt="노트북으로 작업하는 Rabbit Logs 토끼 캐릭터" width="384" height="439" fetchpriority="high" /></div>
    <div class="hero-text">
      <h1>코드는 몰라도,<br />프로세스는 잘 아는 사람.</h1>
      <p class="hero-sub">생산 PI·SAP PP 실무 기록,<br class="mobile-br" /> 그리고 데이터로 넓혀가는 과정.</p>
      <p class="hero-stats">
        {categoryCards.map((c, i) => (
          <>{i > 0 && <span class="dot">·</span>}<span style={`color:${c.color}`}>{c.cat} {c.count}</span></>
        ))}
      </p>
    </div>
  </section>


  <section class="latest">
    <h2 class="section-title">최신 글</h2>
    {posts.map((post) => (
      <PostCard
        href={`/blog/${post.id.replace('ko/', '').replace('.md', '')}`}
        title={post.data.title}
        description={post.data.description}
        category={post.data.category}
        pubDate={post.data.pubDate}
        thumbnail={getThumbnail(post)}
        lang="ko"
      />
    ))}
  </section>

  <section class="cat-explore">
    <h2 class="section-title section-title-accent">카테고리 둘러보기</h2>
    <div class="cat-grid">
      {categoryCards.map((c) => (
        <CategoryCard
          href={c.href}
          catLabel={c.label}
          count={c.count}
          blurb={c.blurb}
          color={c.color}
          thumbnail={c.thumbnail}
        />
      ))}
    </div>
  </section>

  <style>
    .hero { display: flex; align-items: center; gap: 2.5rem; padding: 3rem 0 2.5rem; }
    .hero-img { flex: 0 0 190px; }
    .hero-img img { width: 100%; height: auto; display: block; }
    .hero-text { flex: 1; }
    .hero h1 { font-weight: 800; font-size: 2rem; line-height: 1.3; letter-spacing: -0.03em; margin: 0 0 1rem; }
    .hero-sub { font-size: 1.15rem; color: var(--muted); margin: 0 0 0.7rem; }
    .hero-stats { font-size: 0.85rem; font-weight: 700; margin: 0; }
    .hero-stats .dot { color: var(--muted); margin: 0 0.45rem; font-weight: 400; }
    .mobile-br { display: none; }
    .section-title { font-weight: 800; font-size: 1.1rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; border-bottom: 2px solid var(--primary); padding-bottom: 0.5rem; display: inline-block; }
    .section-title-accent { border-bottom-color: var(--accent); }

    .cat-explore { margin-top: 2.5rem; padding-bottom: 1rem; }
    .cat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; margin-top: 1.2rem; }

    @media (max-width: 640px) {
      .hero { flex-direction: column; text-align: center; gap: 1.2rem; padding: 2rem 0 1.5rem; }
      .hero-img { flex: none; width: 180px; }
      .hero h1 { font-size: 1.85rem; }
      .mobile-br { display: inline; }
      .hero-stats { justify-content: center; flex-wrap: wrap; }
    }
  </style>
</BaseLayout>

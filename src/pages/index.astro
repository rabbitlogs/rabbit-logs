---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import AdSense from '../components/AdSense.astro';

// content/blog/ko/ 안의 글만 가져오기
const posts = (await getCollection('blog'))
  .filter((p) => p.id.startsWith('ko/'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<BaseLayout
  title="Rabbit Logs — SAP PP·PI 구축과 운영 기록"
  description="코드는 몰라도, 프로세스는 잘 아는 사람. 생산 PI·SAP PP 구축과 안정화, 현업의 SAP 실무 기록."
  lang="ko"
  showAds={true}
>
  <section class="hero">
    <div class="hero-img"><img src="/images/hero-rabbit.webp" alt="노트북으로 작업하는 Rabbit Logs 토끼 캐릭터" width="384" height="439" fetchpriority="high" /></div>
    <div class="hero-text">
      <h1>코드는 몰라도,<br />프로세스는 잘 아는 사람.</h1>
      <p class="hero-sub">생산 PI·SAP PP 실무 기록,<br class="mobile-br" /> 그리고 데이터로 넓혀가는 과정.</p>
    </div>
  </section>


  <section class="latest">
    <h2 class="section-title">최신 글</h2>
    {posts.map((post, i) => (
      <>
        <PostCard
          href={`/blog/${post.id.replace('ko/', '').replace('.md', '')}`}
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          pubDate={post.data.pubDate}
          lang="ko"
        />
        {/* 글 3개마다 광고 1개 (목록 흐름을 해치지 않게 카드 사이에만 삽입) */}
        {(i + 1) % 3 === 0 && i !== posts.length - 1 && <AdSense />}
      </>
    ))}
  </section>

  <!--
    목록 페이지 광고 초기화.
    본문(PostLayout)과 달리 위치는 이미 정적으로 고정돼 있으므로(3개마다 1개),
    남은 일은 각 ins.adsbygoogle에 push({})를 호출해 애드센스에 렌더를 요청하고,
    일정 시간 안에 채워지지 않으면(미충전/광고차단) 빈 박스를 제거하는 것뿐이다.
  -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const slots = document.querySelectorAll('.latest .ad-slot');
      slots.forEach((slot) => {
        try { (window.adsbygoogle = window.adsbygoogle || []).push({}); } catch (e) {}

        const ins = slot.querySelector('ins.adsbygoogle');
        if (!ins) return;

        let tries = 0;
        const checker = setInterval(() => {
          tries++;
          const status = ins.getAttribute('data-ad-status');
          const iframe = ins.querySelector('iframe');

          if (status === 'unfilled') {
            slot.remove();
            clearInterval(checker);
          } else if (iframe && iframe.offsetHeight > 0) {
            clearInterval(checker);
          } else if (tries >= 12) {
            slot.remove();
            clearInterval(checker);
          }
        }, 250);
      });
    });
  </script>

  <style>
    .hero { display: flex; align-items: center; gap: 2.5rem; padding: 3rem 0 2.5rem; }
    .hero-img { flex: 0 0 190px; }
    .hero-img img { width: 100%; height: auto; display: block; }
    .hero-text { flex: 1; }
    .hero h1 { font-weight: 800; font-size: 2rem; line-height: 1.3; letter-spacing: -0.03em; margin: 0 0 1rem; }
    .hero-sub { font-size: 1.15rem; color: var(--muted); margin: 0; }
    .mobile-br { display: none; }
    .section-title { font-weight: 800; font-size: 1.1rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; border-bottom: 2px solid var(--primary); padding-bottom: 0.5rem; display: inline-block; }

    @media (max-width: 640px) {
      .hero { flex-direction: column; text-align: center; gap: 1.2rem; padding: 2rem 0 1.5rem; }
      .hero-img { flex: none; width: 180px; }
      .hero h1 { font-size: 1.85rem; }
      .mobile-br { display: inline; }
    }
  </style>
</BaseLayout>

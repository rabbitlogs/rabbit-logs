---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

// content/blog/en/ 안의 글만 가져오기
const posts = (await getCollection('blog'))
  .filter((p) => p.id.startsWith('en/'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<BaseLayout
  title="Rabbit Logs — Notes on SAP PP, PI & S/4HANA"
  description="Not a coder — the view of someone who runs the system. Field notes on building and operating SAP PP and PI."
  lang="en"
>
  <section class="hero">
    <div class="hero-img"><img src="/images/hero-rabbit.webp" alt="Rabbit Logs mascot working on a laptop" width="384" height="439" fetchpriority="high" /></div>
    <div class="hero-text">
      <h1>Not a coder —<br />someone who knows the process.</h1>
      <p class="hero-sub">Field notes from production PI and SAP PP work,<br class="mobile-br" /> and the journey of expanding into data.</p>
    </div>
  </section>


  <section class="latest">
    <h2 class="section-title">Latest</h2>
    {posts.map((post) => (
      <PostCard
        href={`/en/blog/${post.id.replace('en/', '').replace('.md', '')}`}
        title={post.data.title}
        description={post.data.description}
        category={post.data.category}
        pubDate={post.data.pubDate}
        lang="en"
      />
    ))}
  </section>

  <style>
    .hero { display: flex; align-items: center; gap: 2.5rem; padding: 3rem 0 2.5rem; }
    .hero-img { flex: 0 0 190px; }
    .hero-img img { width: 100%; height: auto; display: block; }
    .hero-text { flex: 1; }
    .hero h1 { font-weight: 800; font-size: 2rem; line-height: 1.3; letter-spacing: -0.03em; margin: 0 0 1rem; }
    .hero-sub { font-size: 1.15rem; color: var(--muted); margin: 0; }
    .mobile-br { display: none; }
    .section-title { font-weight: 800; font-size: 1.1rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; border-bottom: 2px solid var(--primary); padding-bottom: 0.5rem; display: inline-block; }

    @media (max-width: 640px) {
      .hero { flex-direction: column; text-align: center; gap: 1.2rem; padding: 2rem 0 1.5rem; }
      .hero-img { flex: none; width: 180px; }
      .hero h1 { font-size: 1.85rem; }
      .mobile-br { display: inline; }
    }
  </style>
</BaseLayout>

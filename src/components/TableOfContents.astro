---
// 글의 소제목(h2, h3)을 모아 목차를 만든다. 클릭하면 해당 위치로 이동.
const { headings = [], lang = 'ko' } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
const label = lang === 'en' ? 'Contents' : '목차';
---

{items.length > 1 && (
  <nav class="toc" aria-label={label}>
    <p class="toc-title">{label}</p>
    <ul>
      {items.map((h) => (
        <li class={h.depth === 3 ? 'sub' : ''}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc {
    margin: 2rem 0;
    padding: 1.1rem 1.4rem;
    background: var(--color-bg-soft, #f3f0e8);
    border: 1px solid var(--line);
    border-radius: 10px;
  }
  .toc-title {
    margin: 0 0 0.6rem;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--primary);
  }
  .toc ul { margin: 0; padding-left: 1.1rem; }
  .toc li { margin: 0.25rem 0; font-size: 0.92rem; line-height: 1.5; }
  .toc li.sub { padding-left: 0.9rem; list-style: circle; }
  .toc a { color: var(--ink); text-decoration: none; }
  .toc a:hover { color: var(--accent); text-decoration: underline; }
</style>

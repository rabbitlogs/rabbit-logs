---
// ─────────────────────────────────────────────
//  애드센스 광고 한 칸
//  - AD_CLIENT: 본인 애드센스 퍼블리셔 ID
//  - AD_SLOT  : 애드센스 "디스플레이 광고" 유닛 번호(data-ad-slot).
//               유닛 1개를 본문 여러 자리에 재사용한다.
// ─────────────────────────────────────────────
const AD_CLIENT = 'ca-pub-9488002130804570';
const AD_SLOT = '3094787370';
---

<div class="ad-slot" aria-label="광고">
  <span class="ad-label">광고</span>
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client={AD_CLIENT}
    data-ad-slot={AD_SLOT}
    data-ad-format="auto"
    data-full-width-responsive="true"
  ></ins>
</div>

<style>
  .ad-slot {
    margin: 2.5rem 0;
    padding: 1.25rem;          /* 광고와 박스 테두리 사이 여백 */
    border: 1px dashed var(--line);
    border-radius: 8px;
    text-align: center;
    overflow: hidden;          /* 모바일에서 박스 밖으로 안 삐짐 */
  }
  .ad-label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 0.75rem;    /* '광고' 글자와 광고 사이 여백 */
  }
  /* ins 높이가 광고 실제 높이를 따라가게 한다.
     PostLayout 스크립트가 광고 로드 후 iframe 높이를 읽어 ins.height를 맞춘다.
     로드 전 기본 높이를 0으로 둬서 박스가 광고보다 길게 남지 않게 한다. */
  .ad-slot .adsbygoogle {
    display: block;
    height: auto;
  }
  .ad-slot .adsbygoogle iframe {
    display: block;            /* iframe 아래 인라인 여백 제거 */
  }
  /* 광고를 못 채운 칸은 통째로 숨김 (빈 점선 박스 제거). */
  .ad-slot:has(ins[data-ad-status="unfilled"]) {
    display: none;
  }
</style>

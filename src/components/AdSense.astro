---
// ─────────────────────────────────────────────
//  애드센스 광고 한 칸 (반응형 auto)
//  - auto + full-width-responsive: AdSense가 그 자리에 맞는 광고를 자동 선택
//  - 광고 크기에 따라 박스 높이가 자동 조정됨 (빈 박스 현상 최소화)
//  - unfilled 시 박스 자체를 숨김
// ─────────────────────────────────────────────
const AD_CLIENT = 'ca-pub-9488002130804570';
const AD_SLOT = '3094787370';
---

<div class="ad-slot" aria-label="광고">
  <span class="ad-label">광고</span>
  <ins
    class="adsbygoogle"
    style="display:block;"
    data-ad-client={AD_CLIENT}
    data-ad-slot={AD_SLOT}
    data-ad-format="auto"
    data-full-width-responsive="true"
  ></ins>
</div>

<style>
  .ad-slot {
    margin: 2.5rem 0;
    padding: 0.75rem;
    border: 1px dashed var(--line);
    border-radius: 8px;
    text-align: center;
  }
  .ad-label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .ad-slot .adsbygoogle {
    display: block;
    width: 100%;
  }
  /* 광고를 못 채운 칸은 통째로 숨김 */
  .ad-slot:has(ins[data-ad-status="unfilled"]) {
    display: none;
  }
</style>

---
// ─────────────────────────────────────────────
//  애드센스 광고 한 칸
//  - AD_CLIENT: 본인 애드센스 퍼블리셔 ID (이미 입력됨)
//  - AD_SLOT  : 애드센스에서 "디스플레이 광고" 유닛 1개 만들면 받는 번호
//               (data-ad-slot 값). 유닛 1개를 본문 여러 자리에 재사용한다.
//               유닛을 만든 뒤 아래 AD_SLOT 한 줄만 그 번호로 바꾸면 끝.
// ─────────────────────────────────────────────
const AD_CLIENT = 'ca-pub-9488002130804570';
const AD_SLOT = '3094787370'; // ← 애드센스 광고 유닛 번호로 교체
---

<div class="ad-slot" aria-label="광고">
  <span class="ad-label">광고</span>
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client={AD_CLIENT}
    data-ad-slot={AD_SLOT}
    data-ad-format="auto"
    data-full-width-responsive="true"
  ></ins>
  <script is:inline>
    (adsbygoogle = window.adsbygoogle || []).push({});
  </script>
</div>

<style>
  .ad-slot {
    margin: 2.5rem 0;
    padding: 0.75rem;
    border: 1px dashed var(--line);
    border-radius: 8px;
    text-align: center;
    min-height: 90px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .ad-label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
  }
</style>

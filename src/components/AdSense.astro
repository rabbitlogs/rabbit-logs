---
// ─────────────────────────────────────────────
//  애드센스 광고 한 칸 (인아티클/fluid 방식)
//  - fluid 광고는 광고 콘텐츠 높이만큼만 차지한다.
//    반응형 auto가 모바일에서 큰 높이를 예약했다가 짧은 광고를 넣어
//    아래 빈칸이 남던 문제를 근본적으로 없앤다.
//  - AD_CLIENT: 본인 애드센스 퍼블리셔 ID
//  - AD_SLOT  : 애드센스 광고 유닛 번호(data-ad-slot)
// ─────────────────────────────────────────────
const AD_CLIENT = 'ca-pub-9488002130804570';
const AD_SLOT = '3094787370';
---

<div class="ad-slot" aria-label="광고">
  <span class="ad-label">광고</span>
  <div class="ad-inner">
    <ins
      class="adsbygoogle"
      style="display:block; text-align:center;"
      data-ad-client={AD_CLIENT}
      data-ad-slot={AD_SLOT}
      data-ad-layout="in-article"
      data-ad-format="fluid"
    ></ins>
  </div>
</div>

<style>
  .ad-slot {
    margin: 2.5rem 0;
    padding: 1.25rem;          /* 박스 테두리 안쪽 여백 */
    border: 1px dashed var(--line);
    border-radius: 8px;
    text-align: center;
    overflow: hidden;
  }
  .ad-label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 0.75rem;    /* '광고' 글자와 광고 사이 여백 */
  }
  .ad-inner {
    /* fluid 광고는 부모 폭 기준으로 스스로 폭을 계산해 padding을 무시한다.
       그래서 좌우 여백은 padding이 아니라, 래퍼 폭 자체를 줄이고
       가운데 정렬해서 만든다(좌우 대칭 보장). */
    width: calc(100% - 1rem);
    margin: 0 auto;
  }
  .ad-slot .adsbygoogle {
    display: block;
  }
  .ad-slot .adsbygoogle iframe {
    display: block;
    margin: 0 auto;
  }
  /* 광고를 못 채운 칸은 통째로 숨김 */
  .ad-slot:has(ins[data-ad-status="unfilled"]) {
    display: none;
  }
</style>

---
// ─────────────────────────────────────────────
//  애드센스 광고 한 칸 (사각형 반응형)
//  - rectangle 포맷 유지 (투명 광고 방지)
//  - PC: max-width 336px (박스 안에 좌우 여백 확보)
//  - 모바일: max-width 300px
// ─────────────────────────────────────────────
const AD_CLIENT = 'ca-pub-9488002130804570';
const AD_SLOT = '3094787370';
---

<div class="ad-slot" aria-label="광고">
  <span class="ad-label">광고</span>
  <ins
    class="adsbygoogle"
    style="display:block;"
    data-ad-client={AD_CLIENT}
    data-ad-slot={AD_SLOT}
    data-ad-format="rectangle"
    data-full-width-responsive="false"
  ></ins>
</div>

<style>
  .ad-slot {
    margin: 2.5rem 0;
    padding: 1.25rem;
    border: 1px dashed var(--line);
    border-radius: 8px;
    text-align: center;
  }
  .ad-label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  /* PC: 336px로 제한, 가운데 정렬 → 박스 안에 좌우 여백 자연스럽게 생김 */
  .ad-slot .adsbygoogle {
    display: block;
    margin: 0 auto;
    max-width: 336px;
  }
  .ad-slot .adsbygoogle iframe {
    display: block;
    margin: 0 auto;
    max-width: 336px;
  }
  /* 모바일: 300px로 제한 */
  @media (max-width: 640px) {
    .ad-slot .adsbygoogle,
    .ad-slot .adsbygoogle iframe {
      max-width: 300px;
    }
  }
  /* 광고를 못 채운 칸은 통째로 숨김 */
  .ad-slot:has(ins[data-ad-status="unfilled"]) {
    display: none;
  }
</style>

---
// 홈 화면 "카테고리 둘러보기" 섹션의 카드 하나.
// 카테고리 대표 글(최신 글)의 썸네일 + 카테고리명·글 수 + 한 줄 소개를 보여준다.
const { href, catLabel, count, blurb, color, thumbnail = null } = Astro.props;
---

<a href={href} class="cat-card">
  {thumbnail ? (
    <img src={thumbnail} alt="" class="cat-thumb" loading="lazy" width="220" height="120" />
  ) : (
    <div class="cat-thumb cat-thumb-empty"></div>
  )}
  <div class="cat-body">
    <div class="cat-label" style={`color:${color}`}>{catLabel} · {count}</div>
    <div class="cat-blurb">{blurb}</div>
  </div>
</a>

<style>
  .cat-card {
    display: block; text-decoration: none; color: inherit;
    background: #fff; border: 1px solid var(--line); border-radius: 10px;
    overflow: hidden; transition: transform 0.15s, box-shadow 0.15s;
  }
  .cat-card:hover { transform: translateY(-2px); box-shadow: 0 4px 14px rgba(32,37,31,0.08); }
  .cat-thumb { width: 100%; height: 90px; object-fit: cover; display: block; }
  .cat-thumb-empty { background: var(--color-bg-soft); }
  .cat-body { padding: 0.65rem 0.75rem; }
  .cat-label { font-size: 0.75rem; font-weight: 700; margin-bottom: 0.15rem; }
  .cat-blurb { font-size: 0.88rem; font-weight: 600; line-height: 1.4; color: var(--ink); }

  @media (max-width: 480px) {
    .cat-thumb { height: 74px; }
  }
</style>

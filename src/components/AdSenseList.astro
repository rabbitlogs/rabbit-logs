---
// ─────────────────────────────────────────────
//  애드센스 광고 한 칸 (목록 페이지 전용 — 가로 고정)
//  - 홈/카테고리처럼 글 카드가 세로로 나열되는 목록 사이에 끼워 넣는 용도.
//  - 본문용 AdSense.astro는 세로형(사각형)이 자연스럽지만,
//    목록에서는 카드 폭에 맞춘 가로로 낮은 배너가 리듬을 덜 깬다.
//  - horizontal 고정 포맷: auto보다 예측 가능한 가로:세로 비율(약 2:1 안팎)로 요청.
//  - full-width-responsive는 그대로 true로 둬서, 목록 컨테이너 폭(약 720px)
//    안에서 비율은 유지한 채 폭에 맞게 늘어나게 한다.
// ─────────────────────────────────────────────
const AD_CLIENT = 'ca-pub-9488002130804570';
const AD_SLOT = '3094787370';
---

<div class="ad-slot" aria-label="광고">
  <span class="ad-label">광고</span>
  <ins
    class="adsbygoogle"
    style="display:block;"
    data-ad-client={AD_CLIENT}
    data-ad-slot={AD_SLOT}
    data-ad-format="horizontal"
    data-full-width-responsive="true"
  ></ins>
</div>

<style>
  .ad-slot {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border: 1px dashed var(--line);
    border-radius: 8px;
    text-align: center;
  }
  .ad-label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }
  /* 가로형: 폭 제한 없이 목록 컨테이너 폭(약 720px)에 맞춰 자연스럽게 늘어남 */
  .ad-slot .adsbygoogle {
    display: block;
    width: 100%;
  }
  /* 광고를 못 채운 칸은 통째로 숨김 */
  .ad-slot:has(ins[data-ad-status="unfilled"]) {
    display: none;
  }
</style>

---
// ─────────────────────────────────────────────
//  애드센스 광고 한 칸 (목록 페이지 전용 — 인아티클/Fluid)
//  - 홈/카테고리처럼 글 카드가 세로로 나열되는 목록 사이에 끼워 넣는 용도.
//  - 본문용 AdSense.astro는 사각형이 자연스럽지만,
//    목록에서는 제목·설명·이미지가 있는 네이티브(카드형) 스타일이 PostCard와 더 잘 섞인다.
//  - in-article 레이아웃 + fluid 포맷: 애드센스가 콘텐츠 카드처럼 보이는 광고를
//    생성해, 목록 컨테이너 폭에 맞춰 반응형으로 채워준다.
//  - 이 슬롯(7098667480)은 애드센스 대시보드에서 "인아티클 광고" 전용으로
//    별도 생성한 것으로, 기존 본문용 슬롯(3094787370)과는 다른 슬롯이다.
// ─────────────────────────────────────────────
const AD_CLIENT = 'ca-pub-9488002130804570';
const AD_SLOT = '7098667480';
---

<div class="ad-slot" aria-label="광고">
  <span class="ad-label">광고</span>
  <ins
    class="adsbygoogle"
    style="display:block; text-align:center;"
    data-ad-layout="in-article"
    data-ad-format="fluid"
    data-ad-client={AD_CLIENT}
    data-ad-slot={AD_SLOT}
  ></ins>
</div>

<style>
  .ad-slot {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border: 1px dashed var(--line);
    border-radius: 8px;
    text-align: center;
  }
  .ad-label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }
  /* 인아티클 광고는 컨테이너 폭(목록 wrap 기준 약 720px)에 맞춰
     자체적으로 반응형 크기를 결정하므로 별도 width/height 강제를 두지 않는다 */
  .ad-slot .adsbygoogle {
    display: block;
  }
  /* 광고를 못 채운 칸은 통째로 숨김 */
  .ad-slot:has(ins[data-ad-status="unfilled"]) {
    display: none;
  }
</style>

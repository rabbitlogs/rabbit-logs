---
const { href, title, description, category, pubDate, thumbnail = null, lang = 'ko' } = Astro.props;

const catName = {
  ko: { project: 'SAP 프로젝트', operations: 'SAP 실무운영', study: 'SAP 학습자료', stats: '통계·데이터' },
  en: { project: 'SAP Projects', operations: 'SAP Operations', study: 'SAP Study Notes', stats: 'Stats & Data' },
};
const dateStr = new Date(pubDate).toLocaleDateString(lang === 'en' ? 'en-US' : 'ko-KR', {
  year: 'numeric', month: 'short', day: 'numeric',
});
---

<a href={href} class="card">
  {thumbnail && (
    <img src={thumbnail} alt="" class="card-thumb" loading="lazy" width="100" height="66" />
  )}
  <div class="card-body">
    <div class="card-meta">
      <span class="cat">{catName[lang][category]}</span>
      <span class="date">{dateStr}</span>
    </div>
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</a>

<style>
  .card {
    display: flex; gap: 1rem; align-items: flex-start;
    text-decoration: none; color: inherit;
    padding: 1.5rem 0; border-bottom: 1px solid var(--line);
    transition: transform 0.15s;
  }
  .card:hover { transform: translateX(4px); }
  .card:last-child { border-bottom: none; padding-bottom: 0; }
  .card:hover h3 { color: var(--primary); }
  .card-thumb {
    width: 100px; height: 66px; object-fit: cover; border-radius: 8px;
    flex-shrink: 0; background: var(--color-bg-soft);
  }
  .card-body { min-width: 0; flex: 1; }
  .card-meta { display: flex; gap: 0.6rem; font-size: 0.8rem; margin-bottom: 0.4rem; }
  .card .cat { color: var(--accent); font-weight: 600; }
  .card .date { color: var(--muted); }
  .card h3 { font-size: 1.3rem; margin: 0 0 0.3rem; transition: color 0.15s; }
  .card p {
    margin: 0; color: var(--muted); font-size: 0.95rem;
    overflow: hidden; text-overflow: ellipsis;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  }

  @media (max-width: 480px) {
    .card-thumb { width: 76px; height: 50px; }
    .card h3 { font-size: 1.1rem; }
  }
</style>
